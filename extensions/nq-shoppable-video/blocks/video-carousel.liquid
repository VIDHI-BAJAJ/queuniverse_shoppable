{{ 'nq-carousel.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://queuniverse-shoppable.vercel.app" crossorigin>
<link rel="dns-prefetch" href="https://queuniverse-shoppable.vercel.app">
<!-- NQ: preconnect to R2/CDN origin so first video loads instantly -->
<link rel="preconnect" href="https://pub-d6dfe6c73ab249958b2610cf47b17860.r2.dev" crossorigin>
<link rel="dns-prefetch" href="https://pub-d6dfe6c73ab249958b2610cf47b17860.r2.dev">
<div id="nq-first-video-preload-{{ block.id }}"></div>

<div class="nq-section nq-tile-type-{{ block.settings.tile_type }}"
     style="padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;">

  <h2 class="nq-heading"
      style="font-size: {{ block.settings.heading_size_desktop }}px; color: {{ block.settings.heading_color }};">
    {{ block.settings.heading }}
  </h2>

  {% assign tt = block.settings.tile_type %}

  {% if tt == 'feed_on_scroll' or tt == 'grid_theme_border' or tt == 'grid_no_border' %}
    <div class="nq-grid" id="nq-carousel-{{ block.id }}">
      <div class="nq-loading">Loading videos...</div>
    </div>

  {% elsif tt == '3d_navigation' %}
    <div class="nq-3d-wrap">
      <button class="nq-3d-prev" id="nq-3d-prev-{{ block.id }}">&#10094;</button>
      <div class="nq-3d-track" id="nq-carousel-{{ block.id }}"></div>
      <button class="nq-3d-next" id="nq-3d-next-{{ block.id }}">&#10095;</button>
    </div>

  {% else %}
    <div class="nq-carousel-wrap">
      <div class="nq-carousel" id="nq-carousel-{{ block.id }}">
        {%- for i in (1..5) -%}
          <div class="nq-skeleton" style="width:{{ block.settings.card_width }}px;height:{{ block.settings.card_height }}px;flex-shrink:0;"></div>
        {%- endfor -%}
      </div>
      <button class="nq-scroll-btn nq-scroll-prev" id="nq-prev-{{ block.id }}">&#10094;</button>
      <button class="nq-scroll-btn nq-scroll-next" id="nq-next-{{ block.id }}">&#10095;</button>
    </div>
  {% endif %}

  {% if tt == 'feed_view_more' %}
    <div class="nq-view-more-wrap">
      <button class="nq-view-more-btn">VIEW MORE &#8964;</button>
    </div>
  {% endif %}

</div>

<!-- Fullscreen Popup -->
<div class="nq-popup" id="nq-popup-{{ block.id }}">
  <div class="nq-popup-overlay" id="nq-popup-overlay-{{ block.id }}"></div>
  <div class="nq-popup-content" id="nq-popup-content-{{ block.id }}">
    <button class="nq-popup-prev" onclick="nqPrevVideo('{{ block.id }}')">&#10094;</button>
    <div class="nq-popup-video-wrap" id="nq-popup-wrap-{{ block.id }}">
      <button class="nq-popup-close" onclick="nqClosePopup('{{ block.id }}')">&#10005;</button>
      <button class="nq-popup-mute" id="nq-popup-mute-{{ block.id }}" onclick="nqToggleMute('{{ block.id }}')">&#128263;</button>
      <video class="nq-popup-video" id="nq-popup-video-{{ block.id }}" autoplay muted playsinline></video>
      <div class="nq-popup-product" id="nq-popup-product-{{ block.id }}"></div>
      <div class="nq-swipe-hint" id="nq-swipe-hint-{{ block.id }}">
        <span>&#8593; Swipe up for next</span>
      </div>
    </div>
    <button class="nq-popup-next" onclick="nqNextVideo('{{ block.id }}')">&#10095;</button>
  </div>
</div>

<script>
(function() {
  var shop     = "{{ shop.permanent_domain }}";
  var API      = "https://queuniverse-shoppable.vercel.app/api/videos";
  var blockId  = "{{ block.id }}";
  var tileType = "{{ block.settings.tile_type }}";
  var btnColor = "{{ block.settings.shop_btn_color }}";
  var cardH    = {{ block.settings.card_height }};
  var cardW    = {{ block.settings.card_width }};
  var allVideos    = [];
  var currentIndex = 0;
  var active3D     = 0;
  var isFetching   = false;

  var productId = null;
  {% if product %}
  productId = "{{ product.id }}";
  {% endif %}

  /* ── Cache helpers: 10-min TTL ── */
  (function purgeLegacyCache() {
    try {
      for (var i = localStorage.length - 1; i >= 0; i--) {
        var k = localStorage.key(i);
        if (k && k.indexOf("nq_") === 0 && k.indexOf("nq_v6_") !== 0) localStorage.removeItem(k);
      }
    } catch(e) {}
  })();

  var CACHE_KEY = "nq_v6_" + shop + (productId ? "_pdp_" + productId : "_home");
  var CACHE_TTL = 10 * 60 * 1000; // 10 minutes

  function readCache() {
    try {
      var raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      var obj = JSON.parse(raw);
      if (Date.now() - obj.ts > CACHE_TTL) { localStorage.removeItem(CACHE_KEY); return null; }
      return obj.data;
    } catch(e) { return null; }
  }

  function writeCache(data) {
    if (!data || !data.videos || !data.videos.length) return;
    try { localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), data: data })); } catch(e) {}
  }

  function bustCache() {
    try { localStorage.removeItem(CACHE_KEY); } catch(e) {}
  }

  /* ════════════════════════════════════════════════════════════
     CORE: filterVideos + renderVideos
     Always called with fresh or cached data.
     Completely re-draws the container every time.
  ════════════════════════════════════════════════════════════ */
  function filterVideos(raw) {
    if (!productId) {
      var filtered = (raw || []).filter(function(v) {
        var s = Array.isArray(v.show_on) ? v.show_on : [];
        return s.indexOf("home") >= 0;
      });
      return filtered.length ? filtered : (raw || []);
    } else {
      var gid = "gid://shopify/Product/" + productId;
      return (raw || []).filter(function(v) {
        var ids = Array.isArray(v.product_ids) ? v.product_ids : [];
        return ids.indexOf(gid) >= 0 || ids.indexOf(productId) >= 0;
      });
    }
  }

  /* ── Inject a <link rel="preload"> for the first video URL so the browser
        fetches it at highest priority, in parallel with everything else.    ── */
  function preloadFirstVideoLink(url) {
    if (!url || document.querySelector('link[data-nq-preload="1"]')) return;
    var link = document.createElement("link");
    link.rel          = "preload";
    link.as           = "video";
    link.href         = url;
    link.setAttribute("data-nq-preload", "1");
    document.head.appendChild(link);
  }

  function renderVideos(data) {
    var raw = (data && data.videos) ? data.videos : [];
    allVideos = filterVideos(raw);

    console.log("[NQ] renderVideos:", allVideos.length, "videos");

    /* Preload first video at highest network priority */
    if (allVideos.length) preloadFirstVideoLink(allVideos[0].r2_url);

    var cont = document.getElementById("nq-carousel-" + blockId);
    if (!cont) { console.warn("[NQ] container not found"); return; }

    cont.innerHTML = "";

    if (!allVideos.length) {
      if (productId) {
        var sec = cont.closest(".nq-section");
        if (sec) sec.style.display = "none";
      } else {
        cont.innerHTML = "<p class='nq-empty'>No videos found.</p>";
      }
      return;
    }

    /* Render first 3 immediately, rest in next frame */
    allVideos.slice(0, 3).forEach(function(v, i) { cont.appendChild(buildCard(v, i)); });

    if (allVideos.length > 3) {
      requestAnimationFrame(function() {
        allVideos.slice(3).forEach(function(v, i) { cont.appendChild(buildCard(v, i + 3)); });
        finishSetup(cont);
      });
    } else {
      finishSetup(cont);
    }
  }

  function finishSetup(cont) {
    if (tileType === "feed_on_scroll")     initScrollReveal(cont);
    else if (tileType === "3d_navigation") init3D();
    else                                   initScrollBtns();
  }

  /* ════════════════════════════════════════════════════════════
     INIT STRATEGY:
     1. Render from cache instantly (0ms delay).
     2. Always kick off a background fetch to refresh data.
     3. On fetch success: update cache + silently refresh view counts.
        If nothing was rendered yet, render now.
  ════════════════════════════════════════════════════════════ */
  var rendered = false;

  function init() {
    rendered = false;
    var cached = readCache();
    if (cached && cached.videos && cached.videos.length) {
      console.log("[NQ] CACHE HIT — instant render");
      renderVideos(cached);
      rendered = true;
    }
    doFetch(); // always refresh in background
  }

  var apiURL = API + "?shop=" + shop + (productId ? "&product_id=gid://shopify/Product/" + productId : "");

  var giveUpTimer = null;
  function doFetch(tries) {
    if (isFetching) return;
    isFetching = true;
    tries = tries || 3;

    if (!rendered) {
      // Only set a timeout error if we haven't shown anything yet
      giveUpTimer = setTimeout(function() {
        if (!rendered) {
          var cont = document.getElementById("nq-carousel-" + blockId);
          if (cont) cont.innerHTML = "<p class='nq-empty' style='padding:20px'>Slow connection — <a href='javascript:location.reload()' style='color:#333;text-decoration:underline'>tap to refresh</a></p>";
        }
      }, 12000);
    }

    console.log("[NQ] Fetching:", apiURL);
    fetch(apiURL)
      .then(function(r) {
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      })
      .then(function(data) {
        isFetching = false;
        if (giveUpTimer) { clearTimeout(giveUpTimer); giveUpTimer = null; }
        var count = data && data.videos ? data.videos.length : 0;
        console.log("[NQ] Fetch OK:", count, "videos");
        writeCache(data);
        if (!rendered) {
          renderVideos(data);
          rendered = true;
        } else {
          /* Already showing from cache — just update view counts silently */
          allVideos = filterVideos(data.videos || []);
          refreshViewCounters();
        }
      })
      .catch(function(err) {
        isFetching = false;
        console.warn("[NQ] Fetch error:", String(err), "retries left:", tries - 1);
        if (tries > 1) {
          setTimeout(function() { isFetching = false; doFetch(tries - 1); }, 3000);
        } else {
          if (giveUpTimer) { clearTimeout(giveUpTimer); giveUpTimer = null; }
          if (!rendered) {
            var cont = document.getElementById("nq-carousel-" + blockId);
            if (cont) cont.innerHTML = "<p class='nq-empty' style='padding:20px'>Could not load — <a href='javascript:location.reload()' style='color:#333;text-decoration:underline'>tap to refresh</a></p>";
          }
        }
      });
  }

  /* ════════════════════════════════════════════════════════════
     NAVIGATION RECOVERY
     Handles ALL the ways a user can come back to this page:
       A) Browser back button     → pageshow (persisted=true)
       B) Tab switch back         → visibilitychange
       C) Normal load             → init() at bottom
  ════════════════════════════════════════════════════════════ */

  /* A) Back button / bfcache restore */
  window.addEventListener("pageshow", function(e) {
    if (!e.persisted) return; // normal load — init() handles it
    console.log("[NQ] pageshow persisted — checking carousel");
    var cont = document.getElementById("nq-carousel-" + blockId);
    if (!cont) return;

    /* Always wipe and re-render on back navigation.
       This is the safest fix — bfcache can restore stale DOM state. */
    rendered = false;
    isFetching = false;
    cont.innerHTML = "";

    var cached = readCache();
    if (cached && cached.videos && cached.videos.length) {
      console.log("[NQ] pageshow: rendering from cache instantly");
      renderVideos(cached);
      rendered = true;
      doFetch(); // refresh in background
    } else {
      console.log("[NQ] pageshow: no cache, fetching");
      doFetch();
    }
  });

  /* B) Tab becomes visible */
  document.addEventListener("visibilitychange", function() {
    if (document.visibilityState !== "visible") return;
    var cont = document.getElementById("nq-carousel-" + blockId);
    if (!cont) return;
    var cardCount = cont.querySelectorAll(".nq-card").length;
    console.log("[NQ] visibilitychange — cards found:", cardCount);

    if (cardCount === 0) {
      /* Carousel is empty — re-render from cache or fetch */
      rendered = false;
      isFetching = false;
      var cached = readCache();
      if (cached && cached.videos && cached.videos.length) {
        console.log("[NQ] visibilitychange: re-rendering from cache");
        renderVideos(cached);
        rendered = true;
      }
      doFetch();
    }
    /* If cards already visible, do nothing — user can see the carousel */
  });

  function refreshViewCounters() {
    var cont = document.getElementById("nq-carousel-" + blockId);
    if (!cont) return;
    cont.querySelectorAll(".nq-card").forEach(function(card, i) {
      if (allVideos[i]) {
        var el = card.querySelector(".nq-views");
        if (el) el.innerHTML = "&#128065; " + (allVideos[i].views || 0);
      }
    });
  }

  /* ════════════════════════════════════════════════════════════
     CARD BUILDER
  ════════════════════════════════════════════════════════════ */
  function buildCard(video, index) {
    var card = document.createElement("div");
    card.className = "nq-card nq-tile-" + tileType;

    var videoEl = document.createElement("video");
    videoEl.muted       = true;
    videoEl.loop        = true;
    videoEl.playsInline = true;
    videoEl.className   = "nq-video-el";

    /* ── FAST VIDEO LOADING STRATEGY ──
       index 0-2 → preload="auto"     + src set immediately (visible cards, buffer fully)
       index 3-5 → preload="metadata" + src set immediately (next scroll targets)
       index 6+  → preload="none"     + lazy src via IntersectionObserver 400px ahead
    */
    if (video.thumbnail_url) videoEl.poster = video.thumbnail_url;
    videoEl.dataset.src = video.r2_url;

    if (index < 3) {
      videoEl.preload = "auto";
      videoEl.src     = video.r2_url;
    } else if (index < 6) {
      videoEl.preload = "metadata";
      videoEl.src     = video.r2_url;
    } else {
      videoEl.preload = "none";
    }

    card.onmouseenter = function() {
      if (!videoEl.src && videoEl.dataset.src) {
        videoEl.src     = videoEl.dataset.src;
        videoEl.preload = "auto";
      }
      videoEl.play().catch(function(){});
    };
    card.onmouseleave = function() { videoEl.pause(); videoEl.currentTime = 0; };
    card.onclick      = function() { nqOpenPopup(blockId, index); };

    /* Only lazy-observe cards that don't already have src (index >= 6) */
    if (index >= 6) {
      if ("IntersectionObserver" in window) {
        new IntersectionObserver(function(entries, obs) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              if (videoEl.dataset.src && !videoEl.src) {
                videoEl.src     = videoEl.dataset.src;
                videoEl.preload = "metadata";
              }
              obs.unobserve(e.target);
            }
          });
        }, { rootMargin: "400px" }).observe(card);
      } else {
        videoEl.src = video.r2_url;
      }
    }

    var views = document.createElement("div");
    views.className = "nq-views";
    views.innerHTML = "&#128065; " + (video.views || 0);

    card.appendChild(videoEl);
    card.appendChild(views);

    switch (tileType) {
      case "img_transparent_text_overlay_3":
      case "img_transparent_text_overlay_2":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-transparent";
          ov.innerHTML = (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
                         '<span class="nq-ov-title">' + p.title + '</span>';
          card.appendChild(ov);
        });
        break;

      case "img_opaque_text_overlay_3":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;overflow:visible;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-opaque";
          ov.innerHTML = (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
                         '<div class="nq-ov-text"><span class="nq-ov-title">' + p.title + '</span>' +
                         '<span class="nq-ov-price">&#8377;' + fmt(p.price) + '</span></div>';
          card.appendChild(ov);
        });
        break;

      case "single_tile_no_overlay":
        card.style.cssText += "width:" + Math.round(cardW * 0.72) + "px;height:" + Math.round(cardH * 0.65) + "px;";
        break;

      case "product_below_3":
      case "product_below_2":
      case "product_below":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;overflow:visible;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var discHtml = '';
          if (p.compare_at_price && p.compare_at_price > p.price) {
            var pct = Math.round((p.compare_at_price - p.price) / p.compare_at_price * 100);
            discHtml = '<span class="nq-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>' +
                       '<span class="nq-disc-badge">' + pct + '% off</span>';
          }
          var info = document.createElement("div");
          info.className = "nq-below-info";
          info.innerHTML = '<p class="nq-below-title">' + p.title + '</p>' +
                           '<p class="nq-below-price">&#8377;' + fmt(p.price) + ' ' + discHtml + '</p>';
          card.appendChild(info);
        });
        break;

      case "story_format":
        card.style.cssText += "width:110px;height:110px;border-radius:50%;";
        views.style.display = "none";
        break;

      case "feed_view_more":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-transparent";
          ov.innerHTML = (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
                         '<span class="nq-ov-title">' + p.title + '</span>';
          card.appendChild(ov);
        });
        break;

      case "feed_on_scroll":
        card.classList.add("nq-scroll-fade");
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var priceRow = '&#8377;' + fmt(p.price);
          if (p.compare_at_price && p.compare_at_price > p.price)
            priceRow += ' <span class="nq-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>';
          var info = document.createElement("div");
          info.className = "nq-below-info";
          info.innerHTML = '<p class="nq-below-title">' + p.title + '</p>' +
                           '<p class="nq-below-price">' + priceRow + '</p>';
          card.appendChild(info);
        });
        break;

      case "grid_theme_border":
        card.style.border = "3px solid " + btnColor;
        break;

      case "grid_no_border":
        card.style.borderRadius = "0";
        break;

      case "3d_navigation":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-transparent";
          ov.innerHTML = (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
                         '<span class="nq-ov-title">' + p.title + '</span>';
          card.appendChild(ov);
        });
        break;

      case "minimal":
      default:
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        break;
    }

    return card;
  }

  /* ════════════════════════════════════════════════════════════
     PRODUCT HELPERS
  ════════════════════════════════════════════════════════════ */
  function fmt(cents) {
    return (Math.round(parseInt(cents)) / 100).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  var _productCache    = {};
  var _allProductsProm = null;

  function prefetchAllProducts() {
    if (_allProductsProm) return _allProductsProm;
    _allProductsProm = fetch("/products.json?limit=250")
      .then(function(r) { return r.json(); })
      .then(function(d) {
        (d.products || []).forEach(function(p) {
          var pid = String(p.id);
          var pv  = p.variants && p.variants[0];
          if (pv && !_productCache[pid]) {
            _productCache[pid] = {
              title:            p.title,
              price:            Math.round(parseFloat(pv.price) * 100),
              compare_at_price: pv.compare_at_price ? Math.round(parseFloat(pv.compare_at_price) * 100) : null,
              handle:           p.handle,
              image:            p.images && p.images[0] ? p.images[0].src : null
            };
          }
        });
        return _productCache;
      }).catch(function() { return {}; });
    return _allProductsProm;
  }
  prefetchAllProducts();

  function fetchProduct(gidOrId) {
    var id = String(gidOrId).replace("gid://shopify/Product/", "").trim();
    if (!id || id === "undefined") return Promise.resolve(null);
    if (_productCache[id]) return Promise.resolve(_productCache[id]);
    return prefetchAllProducts().then(function(c) { return c[id] || null; });
  }

  function getVideoProduct(video) {
    if (video.product_ids && video.product_ids.length) return fetchProduct(video.product_ids[0]);
    if (video.product_handle) {
      return fetch("/products/" + video.product_handle + ".json")
        .then(function(r) { return r.json(); })
        .then(function(d) {
          var pr = d.product, v = pr && pr.variants && pr.variants[0];
          if (!v) return null;
          return {
            title:            pr.title,
            price:            Math.round(parseFloat(v.price) * 100),
            compare_at_price: v.compare_at_price ? Math.round(parseFloat(v.compare_at_price) * 100) : null,
            handle:           pr.handle,
            image:            pr.images && pr.images[0] ? pr.images[0].src : null
          };
        }).catch(function() { return null; });
    }
    return Promise.resolve(null);
  }

  /* ════════════════════════════════════════════════════════════
     SCROLL BUTTONS / SCROLL REVEAL / 3D
  ════════════════════════════════════════════════════════════ */
  function initScrollBtns() {
    var cont = document.getElementById("nq-carousel-" + blockId);
    var prev = document.getElementById("nq-prev-" + blockId);
    var next = document.getElementById("nq-next-" + blockId);
    function upd() {
      if (prev) prev.disabled = cont.scrollLeft <= 2;
      if (next) next.disabled = cont.scrollLeft + cont.clientWidth >= cont.scrollWidth - 2;
    }
    if (prev) prev.onclick = function() { cont.scrollBy({ left: -(cardW + 12), behavior: "smooth" }); setTimeout(upd, 350); };
    if (next) next.onclick = function() { cont.scrollBy({ left:  (cardW + 12), behavior: "smooth" }); setTimeout(upd, 350); };
    cont.addEventListener("scroll", upd, { passive: true });
    upd();
  }

  function initScrollReveal(cont) {
    var cards = cont.querySelectorAll(".nq-scroll-fade");
    if (!("IntersectionObserver" in window)) { cards.forEach(function(c) { c.classList.add("nq-visible"); }); return; }
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add("nq-visible"); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    cards.forEach(function(c) { io.observe(c); });
  }

  function init3D() {
    var track   = document.getElementById("nq-carousel-" + blockId);
    var prevBtn = document.getElementById("nq-3d-prev-" + blockId);
    var nextBtn = document.getElementById("nq-3d-next-" + blockId);
    var cards   = track.querySelectorAll(".nq-card");
    active3D    = Math.floor(cards.length / 2);
    function render3D() {
      cards.forEach(function(card, i) {
        var diff = i - active3D, abs = Math.abs(diff);
        card.style.cssText +=
          ";transform:translateX(" + (diff * cardW * 0.68) + "px) translateZ(" + (abs ? -100 : 0) + "px) rotateY(" + (diff * -24) + "deg) scale(" + (abs === 0 ? 1 : abs === 1 ? 0.80 : 0.65) + ")" +
          ";opacity:" + (abs === 0 ? 1 : abs === 1 ? 0.65 : 0.40) +
          ";z-index:" + (20 - abs) +
          ";transition:all 0.4s cubic-bezier(.4,0,.2,1)";
      });
    }
    if (prevBtn) prevBtn.onclick = function() { if (active3D > 0) { active3D--; render3D(); } };
    if (nextBtn) nextBtn.onclick = function() { if (active3D < cards.length - 1) { active3D++; render3D(); } };
    render3D();
  }

  /* ════════════════════════════════════════════════════════════
     POPUP
  ════════════════════════════════════════════════════════════ */
  var isMuted       = true;
  var touchStartY   = 0;
  var touchStartX   = 0;
  var swipeHintShown = false;

  window.nqOpenPopup = function(bid, index) {
    if (bid !== blockId) return;
    currentIndex = index;
    showPopup(bid);
    var popup = document.getElementById("nq-popup-" + bid);
    popup.classList.add("active");
    document.body.style.overflow = "hidden";
    if (window.innerWidth <= 768) {
      popup.classList.add("nq-popup-mobile");
      if (!swipeHintShown) {
        swipeHintShown = true;
        var hint = document.getElementById("nq-swipe-hint-" + bid);
        if (hint) { hint.classList.add("nq-swipe-hint-show"); setTimeout(function() { hint.classList.remove("nq-swipe-hint-show"); }, 2200); }
      }
    } else {
      popup.classList.remove("nq-popup-mobile");
      var ov = document.getElementById("nq-popup-overlay-" + bid);
      if (ov) ov.onclick = function() { nqClosePopup(bid); };
    }
    var wrap = document.getElementById("nq-popup-wrap-" + bid);
    if (wrap && !wrap._nqSwipeInit) {
      wrap._nqSwipeInit = true;
      wrap.addEventListener("touchstart", function(e) { touchStartY = e.touches[0].clientY; touchStartX = e.touches[0].clientX; }, { passive: true });
      wrap.addEventListener("touchend", function(e) {
        var dy = touchStartY - e.changedTouches[0].clientY;
        var dx = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 50) { dy > 0 ? nqNextVideo(bid) : nqPrevVideo(bid); }
      }, { passive: true });
    }
  };

  window.nqClosePopup = function(bid) {
    if (bid !== blockId) return;
    stopWatchTracking();
    document.getElementById("nq-popup-" + bid).classList.remove("active", "nq-popup-mobile");
    document.getElementById("nq-popup-video-" + bid).pause();
    document.body.style.overflow = "";
  };

  window.nqPrevVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex - 1 + allVideos.length) % allVideos.length;
    showPopup(bid);
  };

  window.nqNextVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex + 1) % allVideos.length;
    showPopup(bid);
  };

  window.nqToggleMute = function(bid) {
    if (bid !== blockId) return;
    var v = document.getElementById("nq-popup-video-" + bid);
    var b = document.getElementById("nq-popup-mute-" + bid);
    isMuted = !isMuted; v.muted = isMuted;
    if (b) b.innerHTML = isMuted ? "&#128263;" : "&#128266;";
  };

  /* ── Analytics ── */
  var TRACK = "https://queuniverse-shoppable.vercel.app/api/track";

  /* trackEvent: same GET pattern as view tracking (which works).
     Returns a Promise so click handler can await it before navigating. */
  function trackEvent(type, video, value) {
    try {
      var url = TRACK + "?video_id=" + video.id + "&shop=" + shop + "&event=" + type + (value ? "&value=" + value : "");
      return fetch(url, { method: "GET", keepalive: true }).catch(function(){});
    } catch(e) { return Promise.resolve(); }
  }
  function trackView(video) {
    trackEvent("view", video);
    video.views = (video.views || 0) + 1;
    bustCache(); // force fresh view count next load
    var cont = document.getElementById("nq-carousel-" + blockId);
    if (cont) {
      var idx = allVideos.indexOf(video);
      var card = cont.querySelectorAll(".nq-card")[idx];
      if (card) { var el = card.querySelector(".nq-views"); if (el) el.innerHTML = "&#128065; " + video.views; }
    }
  }

  var _watchInterval  = null;
  var _watchStartTime = null;   /* ms timestamp when current video session began  */
  var _watchLastTick  = null;   /* ms timestamp of last 5-s tick sent             */
  var _watchVideo     = null;

  function startWatchTracking(video) {
    /* stopWatchTracking() flushes partial time for the PREVIOUS video */
    stopWatchTracking();
    _watchVideo     = video;
    _watchStartTime = Date.now();
    _watchLastTick  = Date.now();
    /* Every 5 seconds, fire a "watch" event with value=5 (seconds) */
    _watchInterval  = setInterval(function() {
      _watchLastTick = Date.now();
      trackEvent("watch", video, 5);
    }, 5000);
  }

  function stopWatchTracking() {
    var p = Promise.resolve();
    if (_watchInterval) {
      clearInterval(_watchInterval);
      _watchInterval = null;
      /* Flush the partial seconds since the last 5-s tick */
      if (_watchVideo && _watchLastTick) {
        var partial = Math.floor((Date.now() - _watchLastTick) / 1000);
        if (partial > 0) { p = trackEvent("watch", _watchVideo, partial) || Promise.resolve(); }
      }
    }
    _watchVideo     = null;
    _watchStartTime = null;
    _watchLastTick  = null;
    return p;
  }

  window.nqTrackClick = function(el) {
    try {
      var vid = el.getAttribute("data-video-id"), sh = el.getAttribute("data-shop");
      if (!vid || !sh) return;
      fetch(TRACK + "?video_id=" + vid + "&shop=" + sh + "&event=click", { method: "GET", keepalive: true }).catch(function(){});
      try { sessionStorage.setItem("nq_last_video", JSON.stringify({ id: vid, shop: sh, ts: Date.now() })); } catch(e) {}
    } catch(e) {}
  };

  /* Order attribution */
  (function() {
    try {
      var isThankYou = window.location.pathname.indexOf("/thank_you") >= 0 ||
                       window.location.pathname.indexOf("/orders/") >= 0 ||
                       (typeof Shopify !== "undefined" && Shopify.checkout);
      if (!isThankYou) return;
      var stored = sessionStorage.getItem("nq_last_video");
      if (!stored) return;
      var last = JSON.parse(stored);
      if (Date.now() - last.ts > 30 * 60 * 1000) return;
      var orderValue = (typeof Shopify !== "undefined" && Shopify.checkout && Shopify.checkout.total_price) ? parseFloat(Shopify.checkout.total_price) : 0;
      fetch(TRACK + "?video_id=" + last.id + "&shop=" + last.shop + "&event=order&value=" + orderValue, { method: "GET", keepalive: true }).catch(function(){});
      sessionStorage.removeItem("nq_last_video");
    } catch(e) {}
  })();

  /* ── Hidden preload video element for popup next-video buffering ── */
  var _preloadVid = document.createElement("video");
  _preloadVid.muted       = true;
  _preloadVid.preload     = "auto";
  _preloadVid.style.display = "none";
  document.body.appendChild(_preloadVid);

  function preloadNextPopupVideo() {
    var nextIdx = (currentIndex + 1) % allVideos.length;
    var nextVideo = allVideos[nextIdx];
    if (nextVideo && nextVideo.r2_url && _preloadVid.src !== nextVideo.r2_url) {
      _preloadVid.src = nextVideo.r2_url;
    }
  }

  function showPopup(bid) {
    /* Always flush the previous video's watch time before starting the next */
    stopWatchTracking();

    var video = allVideos[currentIndex];
    var vid   = document.getElementById("nq-popup-video-" + bid);

    /* If the hidden preloader already buffered this video, swap its source object */
    if (_preloadVid.src === video.r2_url && _preloadVid.readyState >= 2) {
      /* Clone buffered data by pointing popup video at same src — browser cache handles the rest */
      vid.src = video.r2_url;
    } else {
      vid.src = video.r2_url;
    }
    vid.play();
    trackView(video);
    startWatchTracking(video);

    /* Start buffering the next video in the background */
    setTimeout(preloadNextPopupVideo, 500);

    var pd = document.getElementById("nq-popup-product-" + bid);
    pd.innerHTML = "";
    if ((video.product_ids && video.product_ids.length) || (video.product_handle && video.product_handle.length)) {
      getVideoProduct(video).then(function(p) { renderPopupProduct(pd, p, video); });
    }
  }

  function renderPopupProduct(pd, p, video) {
    if (!p) { console.log("[NQ] fetchProduct returned null"); return; }

    var priceHtml   = '&#8377;' + fmt(p.price);
    var compareHtml = '';
    if (p.compare_at_price && p.compare_at_price > p.price) {
      compareHtml = '<span class="nq-popup-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>';
    }
    var videoId = video ? video.id : '';

    /* Build product card HTML */
    var card = document.createElement("div");
    card.className = "nq-popup-product-card";
    if (p.image) {
      var thumb = document.createElement("img");
      thumb.src = p.image;
      thumb.className = "nq-popup-thumb";
      card.appendChild(thumb);
    }
    var info = document.createElement("div");
    info.className = "nq-popup-product-info";
    info.innerHTML = '<p class="nq-popup-product-title">' + p.title + '</p>' +
                     '<p class="nq-popup-product-price">' + priceHtml + ' ' + compareHtml + '</p>';
    card.appendChild(info);
    pd.appendChild(card);

    /* Build SHOP NOW button and attach listener directly — no setTimeout race */
    var shopBtn = document.createElement("a");
    shopBtn.href      = "#";
    shopBtn.className = "nq-popup-shop-btn";
    shopBtn.style.background = btnColor;
    shopBtn.textContent = "SHOP NOW";

    shopBtn.addEventListener("click", function(e) {
      e.preventDefault();
      if (shopBtn._nqClicking) return; // prevent double-fire
      shopBtn._nqClicking = true;

      /* 1. Flush remaining watch seconds for this video */
      stopWatchTracking();

      /* 2. Fire click event — same GET fetch that view tracking uses (proven to work) */
      var clickPromise;
      try {
        var nqPayload = JSON.stringify({ id: videoId, shop: shop, ts: Date.now() });
        sessionStorage.setItem("nq_last_video", nqPayload);
        /* Also backup to localStorage — Gokwik redirects to external domain
           which wipes sessionStorage. Web pixel restores it on return. */
        localStorage.setItem("nq_last_video_backup", nqPayload);
        clickPromise = trackEvent("click", video);
      } catch(err) {
        clickPromise = Promise.resolve();
      }

      /* 3. Wait up to 500ms for the click request to complete, then navigate.
            500ms is enough for a fast connection; keepalive ensures it even if we navigate early. */
      var handle = p.handle;
      var done = false;
      function go() {
        if (done) return;
        done = true;
        window.location.href = "/products/" + handle;
      }
      clickPromise.then(go).catch(go);
      setTimeout(go, 500);
    });

    pd.appendChild(shopBtn);
  }


  init();

})();
</script>

<!-- NQ Keep-Warm: warms Vercel + pre-populates cache -->
<script>
(function() {
  if (window._nqWarmInit) return;
  window._nqWarmInit = true;

  var API  = "https://queuniverse-shoppable.vercel.app/api/videos";
  var shop = "{{ shop.permanent_domain }}";
  var url  = API + "?shop=" + shop;
  var KEY  = "nq_v6_" + shop + "_home";
  var TTL  = 10 * 60 * 1000;

  function ping() {
    fetch(url, { keepalive: true })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data || !data.videos || !data.videos.length) return;
        try {
          var raw = localStorage.getItem(KEY);
          // Write cache if missing OR if older than TTL
          var shouldWrite = !raw;
          if (!shouldWrite) {
            var obj = JSON.parse(raw);
            if (Date.now() - obj.ts > TTL) shouldWrite = true;
          }
          if (shouldWrite) {
            localStorage.setItem(KEY, JSON.stringify({ ts: Date.now(), data: data }));
            console.log("[NQ Keep-warm] Cache updated:", data.videos.length, "videos");
          }
          /* Preload the first video from R2 so it is in browser cache on page load */
          try {
            var firstVid = data.videos[0];
            if (firstVid && firstVid.r2_url) {
              var vLink = document.querySelector('link[data-nq-keepwarm="1"]');
              if (!vLink) {
                vLink = document.createElement("link");
                vLink.rel = "preload";
                vLink.as  = "video";
                vLink.setAttribute("data-nq-keepwarm", "1");
                document.head.appendChild(vLink);
              }
              vLink.href = firstVid.r2_url;
            }
          } catch(e) {}
        } catch(e) {}
      })
      .catch(function() { setTimeout(ping, 20000); });
  }

  ping();
  setInterval(ping, 4 * 60 * 1000);
  document.addEventListener("visibilitychange", function() {
    if (document.visibilityState === "visible") ping();
  });
})();
</script>


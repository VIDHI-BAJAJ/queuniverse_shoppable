{{ 'nq-carousel.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://queuniverse-shoppable.vercel.app" crossorigin>
<link rel="dns-prefetch" href="https://queuniverse-shoppable.vercel.app">

<div class="nq-section nq-tile-type-{{ block.settings.tile_type }}"
     style="padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;">

  <h2 class="nq-heading"
      style="font-size: {{ block.settings.heading_size_desktop }}px; color: {{ block.settings.heading_color }};">
    {{ block.settings.heading }}
  </h2>

  {% assign tt = block.settings.tile_type %}

  {% if tt == 'feed_on_scroll' or tt == 'grid_theme_border' or tt == 'grid_no_border' %}
    <div class="nq-grid" id="nq-carousel-{{ block.id }}">
      <div class="nq-loading">Loading videos...</div>
    </div>

  {% elsif tt == '3d_navigation' %}
    <div class="nq-3d-wrap">
      <button class="nq-3d-prev" id="nq-3d-prev-{{ block.id }}">&#10094;</button>
      <div class="nq-3d-track" id="nq-carousel-{{ block.id }}"></div>
      <button class="nq-3d-next" id="nq-3d-next-{{ block.id }}">&#10095;</button>
    </div>

  {% else %}
    <div class="nq-carousel-wrap">
      <div class="nq-carousel" id="nq-carousel-{{ block.id }}">
        {%- for i in (1..5) -%}
          <div class="nq-skeleton" style="width:{{ block.settings.card_width }}px;height:{{ block.settings.card_height }}px;flex-shrink:0;"></div>
        {%- endfor -%}
      </div>
      <button class="nq-scroll-btn nq-scroll-prev" id="nq-prev-{{ block.id }}">&#10094;</button>
      <button class="nq-scroll-btn nq-scroll-next" id="nq-next-{{ block.id }}">&#10095;</button>
    </div>
  {% endif %}

  {% if tt == 'feed_view_more' %}
    <div class="nq-view-more-wrap">
      <button class="nq-view-more-btn">VIEW MORE &#8964;</button>
    </div>
  {% endif %}

</div>

<!-- Fullscreen Popup — Desktop: left/right arrows | Mobile: full-screen reel swipe -->
<div class="nq-popup" id="nq-popup-{{ block.id }}">
  <!-- Desktop overlay click to close -->
  <div class="nq-popup-overlay" id="nq-popup-overlay-{{ block.id }}"></div>

  <!-- Desktop layout: prev | video | next -->
  <div class="nq-popup-content" id="nq-popup-content-{{ block.id }}">
    <button class="nq-popup-prev" onclick="nqPrevVideo('{{ block.id }}')">&#10094;</button>
    <div class="nq-popup-video-wrap" id="nq-popup-wrap-{{ block.id }}">
      <!-- Close button -->
      <button class="nq-popup-close" onclick="nqClosePopup('{{ block.id }}')">&#10005;</button>
      <!-- Mute toggle -->
      <button class="nq-popup-mute" id="nq-popup-mute-{{ block.id }}" onclick="nqToggleMute('{{ block.id }}')">&#128263;</button>
      <!-- Video -->
      <video class="nq-popup-video" id="nq-popup-video-{{ block.id }}" autoplay muted playsinline></video>
      <!-- Product card -->
      <div class="nq-popup-product" id="nq-popup-product-{{ block.id }}"></div>
      <!-- Mobile swipe hint (shown briefly on first open) -->
      <div class="nq-swipe-hint" id="nq-swipe-hint-{{ block.id }}">
        <span>&#8593; Swipe up for next</span>
      </div>
    </div>
    <button class="nq-popup-next" onclick="nqNextVideo('{{ block.id }}')">&#10095;</button>
  </div>
</div>

<script>
(function() {
  var shop     = "{{ shop.permanent_domain }}";
  var API      = "https://queuniverse-shoppable.vercel.app/api/videos";
  var blockId  = "{{ block.id }}";
  var tileType = "{{ block.settings.tile_type }}";
  var btnColor = "{{ block.settings.shop_btn_color }}";
  var cardH    = {{ block.settings.card_height }};
  var cardW    = {{ block.settings.card_width }};
  var allVideos = [];
  var currentIndex = 0;
  var active3D = 0;

  // Detect if we are on a product page
  var productId = null;
  {% if product %}
  productId = "{{ product.id }}";
  {% endif %}

  /* ── CACHE: v5 — clears all old broken cache on every page load ── */
  (function() {
    try {
      var keysToRemove = [];
      for (var i = 0; i < localStorage.length; i++) {
        var k = localStorage.key(i);
        if (k && k.indexOf("nq_") === 0 && k.indexOf("nq_v5_") !== 0) {
          keysToRemove.push(k);
        }
      }
      keysToRemove.forEach(function(k) { localStorage.removeItem(k); });
    } catch(e) {}
  })();

  var CACHE_KEY = "nq_v5_" + shop + (productId ? "_pdp_" + productId : "_home");
  var rendered  = false;

  function readCache() {
    try {
      var raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      var obj = JSON.parse(raw);
      // 5 minute TTL (300000ms) — keeps view counts fresh
      if (Date.now() - obj.ts > 300000) { localStorage.removeItem(CACHE_KEY); return null; }
      return obj.data;
    } catch(e) { return null; }
  }

  function writeCache(data) {
    try { localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), data: data })); } catch(e) {}
  }

  function bustCache() {
    try { localStorage.removeItem(CACHE_KEY); } catch(e) {}
  }

  function renderVideos(data) {
    var raw = (data && data.videos) ? data.videos : [];

    // Client-side filter: homepage shows only show_on=home, PDP shows only matching product
    if (!productId) {
      // Homepage — filter to videos marked for homepage
      allVideos = raw.filter(function(v) {
        var showOn = Array.isArray(v.show_on) ? v.show_on : [];
        return showOn.includes("home") || showOn.indexOf("home") >= 0;
      });
      // If none marked for homepage, show all live videos as fallback
      if (allVideos.length === 0 && raw.length > 0) allVideos = raw;
    } else {
      // PDP — filter to videos tagged with this product
      var gid = "gid://shopify/Product/" + productId;
      allVideos = raw.filter(function(v) {
        var ids = Array.isArray(v.product_ids) ? v.product_ids : [];
        return ids.indexOf(gid) >= 0 || ids.indexOf(productId) >= 0;
      });
    }

    console.log("[NQ " + blockId + "] Rendering", allVideos.length, "of", raw.length, "videos");
    var cont = document.getElementById("nq-carousel-" + blockId);
    if (!cont) { console.log("[NQ] Container not found!"); return; }
    cont.innerHTML = "";
    if (!allVideos.length) {
      if (productId) {
        var section = cont.closest(".nq-section");
        if (section) section.style.display = "none";
      } else {
        cont.innerHTML = "<p class='nq-empty'>No videos found.</p>";
      }
      return;
    }
    rendered = true;
    allVideos.slice(0, 3).forEach(function(v, i) { cont.appendChild(buildCard(v, i)); });
    if (allVideos.length > 3) {
      requestAnimationFrame(function() {
        allVideos.slice(3).forEach(function(v, i) { cont.appendChild(buildCard(v, i + 3)); });
        finishSetup(cont);
      });
    } else {
      finishSetup(cont);
    }
  }

  function finishSetup(cont) {
    if (tileType === "feed_on_scroll")     initScrollReveal(cont);
    else if (tileType === "3d_navigation") init3D();
    else                                   initScrollBtns();
  }

  // Step 1: instant render from cache
  var cached = readCache();
  if (cached) {
    console.log("[NQ " + blockId + "] Cache HIT");
    renderVideos(cached);
  } else {
    console.log("[NQ " + blockId + "] Cache MISS — fetching API");
  }

  // Step 2: fetch fresh data
  var apiURL = API + "?shop=" + shop + (productId ? "&product_id=gid://shopify/Product/" + productId : "");
  var giveUp = setTimeout(function() {
    if (!rendered) {
      var cont = document.getElementById("nq-carousel-" + blockId);
      if (cont) cont.innerHTML = "<p class='nq-empty' style='padding:20px'>Slow connection — <a href='javascript:location.reload()' style='color:#333;text-decoration:underline'>tap to refresh</a></p>";
    }
  }, 15000);

  function doFetch(tries) {
    console.log("[NQ " + blockId + "] Fetching:", apiURL);
    fetch(apiURL)
      .then(function(r) {
        console.log("[NQ] HTTP:", r.status, "URL:", r.url);
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      })
      .then(function(data) {
        clearTimeout(giveUp);
        var count = data && data.videos ? data.videos.length : 0;
        console.log("[NQ] Got", count, "videos. Error:", data && data.error);
        if (data && data.error) {
          console.error("[NQ] API error:", data.error);
        }
        writeCache(data);
        if (!rendered) {
          renderVideos(data);
        } else {
          allVideos = data.videos || [];
          refreshAllViewCounters();
        }
      })
      .catch(function(err) {
        console.log("[NQ] Fetch error:", String(err), "tries left:", tries - 1);
        if (tries > 1) {
          setTimeout(function() { doFetch(tries - 1); }, 3000);
        } else {
          clearTimeout(giveUp);
          if (!rendered) {
            var cont = document.getElementById("nq-carousel-" + blockId);
            if (cont) cont.innerHTML = "<p class='nq-empty' style='padding:20px'>Could not load — <a href='javascript:location.reload()' style='color:#333;text-decoration:underline'>tap to refresh</a></p>";
          }
        }
      });
  }

  doFetch(3);

  /* ── Refresh all view counters on cards after fresh fetch ── */
  function refreshAllViewCounters() {
    var cont = document.getElementById("nq-carousel-" + blockId);
    if (!cont) return;
    var cards = cont.querySelectorAll(".nq-card");
    cards.forEach(function(card, i) {
      if (allVideos[i]) {
        var viewEl = card.querySelector(".nq-views");
        if (viewEl) viewEl.innerHTML = "&#128065; " + (allVideos[i].views || 0);
      }
    });
  }

  /* ───────────────────────── Card Builder ───────────────────────── */
  function buildCard(video, index) {
    var card = document.createElement("div");
    card.className = "nq-card nq-tile-" + tileType;

    var videoEl = document.createElement("video");
    videoEl.muted       = true;
    videoEl.loop        = true;
    videoEl.playsInline = true;
    videoEl.className   = "nq-video-el";
    // Show thumbnail as poster so card never shows black while loading
    // Always lazy-load — thumbnail covers black, no src until hover/visible
    videoEl.preload = "none";
    if (video.thumbnail_url) videoEl.poster = video.thumbnail_url;
    videoEl.dataset.src = video.r2_url;

    card.onmouseenter = function() {
      if (!videoEl.src && videoEl.dataset.src) videoEl.src = videoEl.dataset.src;
      videoEl.play().catch(function(){});
    };
    card.onmouseleave = function() { videoEl.pause(); videoEl.currentTime = 0; };
    card.onclick = function() { nqOpenPopup(blockId, index); };

    if ("IntersectionObserver" in window) {
      (new IntersectionObserver(function(entries, obs) {
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            if (videoEl.dataset.src && !videoEl.src) {
              videoEl.src = videoEl.dataset.src;
            }
            obs.unobserve(e.target);
          }
        });
      }, { rootMargin: "200px" })).observe(card);
    } else {
      videoEl.src = video.r2_url;
    }

    var views = document.createElement("div");
    views.className = "nq-views";
    views.innerHTML = "&#128065; " + (video.views || 0);

    card.appendChild(videoEl);
    card.appendChild(views);

    switch (tileType) {

      case "img_transparent_text_overlay_3":
      case "img_transparent_text_overlay_2":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-transparent";
          ov.innerHTML =
            (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
            '<span class="nq-ov-title">' + p.title + '</span>';
          card.appendChild(ov);
        });
        break;

      case "img_opaque_text_overlay_3":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;overflow:visible;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-opaque";
          ov.innerHTML =
            (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
            '<div class="nq-ov-text">' +
              '<span class="nq-ov-title">' + p.title + '</span>' +
              '<span class="nq-ov-price">&#8377;' + fmt(p.price) + '</span>' +
            '</div>';
          card.appendChild(ov);
        });
        break;

      case "single_tile_no_overlay":
        card.style.cssText += "width:" + Math.round(cardW * 0.72) + "px;height:" + Math.round(cardH * 0.65) + "px;";
        break;

      case "product_below_3":
      case "product_below_2":
      case "product_below":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;overflow:visible;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var discHtml = '';
          if (p.compare_at_price && p.compare_at_price > p.price) {
            var pct = Math.round((p.compare_at_price - p.price) / p.compare_at_price * 100);
            discHtml =
              '<span class="nq-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>' +
              '<span class="nq-disc-badge">' + pct + '% off</span>';
          }
          var info = document.createElement("div");
          info.className = "nq-below-info";
          info.innerHTML =
            '<p class="nq-below-title">' + p.title + '</p>' +
            '<p class="nq-below-price">&#8377;' + fmt(p.price) + ' ' + discHtml + '</p>';
          card.appendChild(info);
        });
        break;

      case "story_format":
        card.style.cssText += "width:110px;height:110px;border-radius:50%;";
        views.style.display = "none";
        break;

      case "feed_view_more":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-transparent";
          ov.innerHTML =
            (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
            '<span class="nq-ov-title">' + p.title + '</span>';
          card.appendChild(ov);
        });
        break;

      case "feed_on_scroll":
        card.classList.add("nq-scroll-fade");
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var priceRow = '&#8377;' + fmt(p.price);
          if (p.compare_at_price && p.compare_at_price > p.price) {
            priceRow += ' <span class="nq-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>';
          }
          var info = document.createElement("div");
          info.className = "nq-below-info";
          info.innerHTML =
            '<p class="nq-below-title">' + p.title + '</p>' +
            '<p class="nq-below-price">' + priceRow + '</p>';
          card.appendChild(info);
        });
        break;

      case "grid_theme_border":
        card.style.border = "3px solid " + btnColor;
        break;

      case "grid_no_border":
        card.style.borderRadius = "0";
        break;

      case "3d_navigation":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        getVideoProduct(video).then(function(p) {
          if (!p) return;
          var ov = document.createElement("div");
          ov.className = "nq-ov-transparent";
          ov.innerHTML =
            (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
            '<span class="nq-ov-title">' + p.title + '</span>';
          card.appendChild(ov);
        });
        break;

      case "minimal":
      default:
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        break;
    }

    return card;
  }

  /* ───────────────────────── Helpers ───────────────────────── */
  function fmt(cents) {
    return (Math.round(parseInt(cents)) / 100).toLocaleString('en-IN', {minimumFractionDigits: 0, maximumFractionDigits: 0});
  }

  // Product cache — keyed by numeric ID
  var _productCache = {};
  // Track in-flight fetches to avoid duplicate requests
  var _productFetching = {};

  function fetchProduct(productGidOrId) {
    var id = String(productGidOrId).replace("gid://shopify/Product/", "").trim();
    if (!id || id === "undefined") return Promise.resolve(null);
    // Return from cache
    if (_productCache[id]) return Promise.resolve(_productCache[id]);
    // Return in-flight promise to avoid duplicate fetches
    if (_productFetching[id]) return _productFetching[id];

    // Fetch by handle using Shopify AJAX recommendations
    // We use /recommendations/products.json with the product_id to get related,
    // but for exact fetch we use the variant-based search
    // Most reliable: fetch product page JSON by GID via collections
    var promise = fetch("/products.json?limit=250")
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var products = d.products || [];
        var pr = null;
        for (var i = 0; i < products.length; i++) {
          if (String(products[i].id) === String(id)) { pr = products[i]; break; }
        }
        if (!pr) return null;
        var v = pr.variants && pr.variants[0];
        if (!v) return null;
        var result = {
          title:            pr.title,
          price:            Math.round(parseFloat(v.price) * 100),
          compare_at_price: v.compare_at_price ? Math.round(parseFloat(v.compare_at_price) * 100) : null,
          handle:           pr.handle,
          image:            pr.images && pr.images[0] ? pr.images[0].src : null
        };
        // Cache all products from this response to avoid future fetches
        products.forEach(function(p) {
          var pid = String(p.id);
          if (!_productCache[pid]) {
            var pv = p.variants && p.variants[0];
            if (pv) {
              _productCache[pid] = {
                title:            p.title,
                price:            Math.round(parseFloat(pv.price) * 100),
                compare_at_price: pv.compare_at_price ? Math.round(parseFloat(pv.compare_at_price) * 100) : null,
                handle:           p.handle,
                image:            p.images && p.images[0] ? p.images[0].src : null
              };
            }
          }
        });
        delete _productFetching[id];
        return result;
      }).catch(function() { delete _productFetching[id]; return null; });

    _productFetching[id] = promise;
    return promise;
  }

  function getVideoProduct(video) {
    if (video.product_ids && video.product_ids.length) {
      return fetchProduct(video.product_ids[0]);
    }
    if (video.product_handle) {
      return fetch("/products/" + video.product_handle + ".json")
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (!d.product || !d.product.variants || !d.product.variants[0]) return null;
          var pr = d.product;
          var v  = pr.variants[0];
          return {
            title:            pr.title,
            price:            Math.round(parseFloat(v.price) * 100),
            compare_at_price: v.compare_at_price ? Math.round(parseFloat(v.compare_at_price) * 100) : null,
            handle:           pr.handle,
            image:            pr.images && pr.images[0] ? pr.images[0].src : null
          };
        }).catch(function() { return null; });
    }
    return Promise.resolve(null);
  }

  /* ───────────────────────── Scroll Buttons ─────────────────── */
  function initScrollBtns() {
    var container = document.getElementById("nq-carousel-" + blockId);
    var prev = document.getElementById("nq-prev-" + blockId);
    var next = document.getElementById("nq-next-" + blockId);

    function updateArrows() {
      if (prev) prev.disabled = container.scrollLeft <= 2;
      if (next) next.disabled = container.scrollLeft + container.clientWidth >= container.scrollWidth - 2;
    }

    if (prev) prev.onclick = function() {
      container.scrollBy({ left: -(cardW + 12), behavior: "smooth" });
      setTimeout(updateArrows, 350);
    };
    if (next) next.onclick = function() {
      container.scrollBy({ left: (cardW + 12), behavior: "smooth" });
      setTimeout(updateArrows, 350);
    };

    container.addEventListener("scroll", updateArrows, { passive: true });
    updateArrows();
  }

  /* ───────────────────────── Scroll Reveal ──────────────────── */
  function initScrollReveal(container) {
    var cards = container.querySelectorAll(".nq-scroll-fade");
    if (!("IntersectionObserver" in window)) {
      cards.forEach(function(c) { c.classList.add("nq-visible"); });
      return;
    }
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add("nq-visible"); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    cards.forEach(function(c) { io.observe(c); });
  }

  /* ───────────────────────── 3D Coverflow ──────────────────── */
  function init3D() {
    var track   = document.getElementById("nq-carousel-" + blockId);
    var prevBtn = document.getElementById("nq-3d-prev-" + blockId);
    var nextBtn = document.getElementById("nq-3d-next-" + blockId);
    var cards   = track.querySelectorAll(".nq-card");
    active3D    = Math.floor(cards.length / 2);

    function render() {
      cards.forEach(function(card, i) {
        var diff  = i - active3D;
        var abs   = Math.abs(diff);
        var scale = abs === 0 ? 1 : abs === 1 ? 0.80 : 0.65;
        var tx    = diff * (cardW * 0.68);
        var tz    = abs === 0 ? 0 : -100;
        var ry    = diff * -24;
        var op    = abs === 0 ? 1 : abs === 1 ? 0.65 : 0.40;
        card.style.cssText +=
          ";transform:translateX(" + tx + "px) translateZ(" + tz + "px) rotateY(" + ry + "deg) scale(" + scale + ")" +
          ";opacity:" + op +
          ";z-index:" + (20 - abs) +
          ";transition:all 0.4s cubic-bezier(.4,0,.2,1)";
      });
    }

    if (prevBtn) prevBtn.onclick = function() { if (active3D > 0) { active3D--; render(); } };
    if (nextBtn) nextBtn.onclick = function() { if (active3D < cards.length - 1) { active3D++; render(); } };
    render();
  }

  /* ───────────────────────── Popup ─────────────────────────── */
  var isMuted = true;
  var touchStartY = 0;
  var touchStartX = 0;
  var swipeHintShown = false;

  window.nqOpenPopup = function(bid, index) {
    if (bid !== blockId) return;
    currentIndex = index;
    showPopup(bid);

    var popup = document.getElementById("nq-popup-" + bid);
    popup.classList.add("active");
    document.body.style.overflow = "hidden";

    if (window.innerWidth <= 768) {
      popup.classList.add("nq-popup-mobile");
      if (!swipeHintShown) {
        swipeHintShown = true;
        var hint = document.getElementById("nq-swipe-hint-" + bid);
        if (hint) {
          hint.classList.add("nq-swipe-hint-show");
          setTimeout(function() { hint.classList.remove("nq-swipe-hint-show"); }, 2200);
        }
      }
    } else {
      popup.classList.remove("nq-popup-mobile");
      var overlay = document.getElementById("nq-popup-overlay-" + bid);
      if (overlay) overlay.onclick = function() { nqClosePopup(bid); };
    }

    var wrap = document.getElementById("nq-popup-wrap-" + bid);
    if (wrap && !wrap._nqSwipeInit) {
      wrap._nqSwipeInit = true;

      wrap.addEventListener("touchstart", function(e) {
        touchStartY = e.touches[0].clientY;
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      wrap.addEventListener("touchend", function(e) {
        var dy = touchStartY - e.changedTouches[0].clientY;
        var dx = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 50) {
          if (dy > 0) {
            nqNextVideo(bid);
          } else {
            nqPrevVideo(bid);
          }
        }
      }, { passive: true });
    }
  };

  window.nqClosePopup = function(bid) {
    if (bid !== blockId) return;
    var popup = document.getElementById("nq-popup-" + bid);
    popup.classList.remove("active", "nq-popup-mobile");
    document.getElementById("nq-popup-video-" + bid).pause();
    document.body.style.overflow = "";
  };

  window.nqPrevVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex - 1 + allVideos.length) % allVideos.length;
    showPopup(bid);
  };

  window.nqNextVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex + 1) % allVideos.length;
    showPopup(bid);
  };

  window.nqToggleMute = function(bid) {
    if (bid !== blockId) return;
    var videoEl = document.getElementById("nq-popup-video-" + bid);
    var muteBtn = document.getElementById("nq-popup-mute-" + bid);
    isMuted = !isMuted;
    videoEl.muted = isMuted;
    if (muteBtn) muteBtn.innerHTML = isMuted ? "&#128263;" : "&#128266;";
  };

  /* ── trackView: increment in Supabase + update UI live ── */
  function trackView(video) {
    try {
      fetch("https://queuniverse-shoppable.vercel.app/api/track?video_id=" + video.id + "&shop=" + shop, {
        method: "GET",
        keepalive: true
      })
      .then(function(r) { return r.json(); })
      .then(function() {
        // 1. Increment locally so UI updates instantly without waiting for API
        video.views = (video.views || 0) + 1;

        // 2. Update the view badge on the card in the carousel
        var cont = document.getElementById("nq-carousel-" + blockId);
        if (cont) {
          var cards = cont.querySelectorAll(".nq-card");
          var idx = allVideos.indexOf(video);
          if (idx >= 0 && cards[idx]) {
            var viewEl = cards[idx].querySelector(".nq-views");
            if (viewEl) viewEl.innerHTML = "&#128065; " + video.views;
          }
        }

        // 3. Bust the cache so next page load fetches fresh counts from Supabase
        bustCache();
      })
      .catch(function(){});
    } catch(e) {}
  }

  function showPopup(bid) {
    var video   = allVideos[currentIndex];
    var videoEl = document.getElementById("nq-popup-video-" + bid);
    videoEl.src = video.r2_url;
    videoEl.play();
    trackView(video);

    var pd = document.getElementById("nq-popup-product-" + bid);
    pd.innerHTML = "";

    var hasProductIds = video.product_ids && video.product_ids.length;
    var hasHandle     = video.product_handle && video.product_handle.length;

    console.log("[NQ Popup] video product_ids:", video.product_ids, "| product_handle:", video.product_handle);

    if (hasProductIds || hasHandle) {
      getVideoProduct(video).then(function(p) {
        renderPopupProduct(pd, p);
      });
    } else {
      console.log("[NQ Popup] No product linked to this video.");
    }
  }

  function renderPopupProduct(pd, p) {
    if (!p) { console.log("[NQ] fetchProduct returned null"); return; }
    console.log("[NQ] Rendering product:", p.title, p.price, p.handle);

    var priceHtml   = '&#8377;' + fmt(p.price);
    var compareHtml = '';
    if (p.compare_at_price && p.compare_at_price > p.price) {
      compareHtml = '<span class="nq-popup-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>';
    }

    pd.innerHTML =
      '<div class="nq-popup-product-card">' +
        (p.image ? '<img src="' + p.image + '" class="nq-popup-thumb">' : '') +
        '<div class="nq-popup-product-info">' +
          '<p class="nq-popup-product-title">' + p.title + '</p>' +
          '<p class="nq-popup-product-price">' + priceHtml + ' ' + compareHtml + '</p>' +
        '</div>' +
      '</div>' +
      '<a href="/products/' + p.handle + '" class="nq-popup-shop-btn" style="background:' + btnColor + '">SHOP NOW</a>';
  }
})();
</script>

<!-- NQ Keep-Warm: fires immediately + every 4min to prevent Vercel cold start -->
<script>
(function() {
  if (window._nqWarmInit) return;
  window._nqWarmInit = true;

  var API  = "https://queuniverse-shoppable.vercel.app/api/videos";
  var shop = "{{ shop.permanent_domain }}";
  // Keep-warm pings homepage context — uses correct cache key matching the carousel
  var url  = API + "?shop=" + shop;
  var CACHE_KEY = "nq_v3_" + shop + "_home";

  function ping() {
    fetch(url, { keepalive: true })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data && data.videos) {
          try {
            localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), data: data }));
          } catch(e) {}
        }
      })
      .catch(function() {
        setTimeout(ping, 20000);
      });
  }

  ping();
  setInterval(ping, 4 * 60 * 1000);

  document.addEventListener("visibilitychange", function() {
    if (document.visibilityState === "visible") ping();
  });
})();
</script>


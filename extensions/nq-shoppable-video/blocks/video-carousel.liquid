{{ 'nq-carousel.css' | asset_url | stylesheet_tag }}

<div class="nq-section">
  <h2 class="nq-heading" style="font-size: {{ block.settings.heading_size_desktop }}px; color: {{ block.settings.heading_color }};">
  {{ block.settings.heading }}
</h2>
  <div class="nq-carousel" id="nq-carousel-{{ block.id }}">
    <div class="nq-loading">Loading videos...</div>
  </div>
</div>

<!-- Fullscreen Popup -->
<div class="nq-popup" id="nq-popup-{{ block.id }}">
  <div class="nq-popup-overlay" onclick="nqClosePopup('{{ block.id }}')"></div>
  <div class="nq-popup-content">
    <button class="nq-popup-close" onclick="nqClosePopup('{{ block.id }}')">✕</button>
    <button class="nq-popup-prev" onclick="nqPrevVideo('{{ block.id }}')">❮</button>
    <button class="nq-popup-next" onclick="nqNextVideo('{{ block.id }}')">❯</button>
    <div class="nq-popup-video-wrap">
      <video class="nq-popup-video" id="nq-popup-video-{{ block.id }}" autoplay muted playsinline controls></video>
      <div class="nq-popup-product" id="nq-popup-product-{{ block.id }}"></div>
    </div>
  </div>
</div>

<script>
(function() {
  var shop = "{{ shop.permanent_domain }}";
  var API = "https://queuniverse-shoppable.vercel.app/api/videos";
  var blockId = "{{ block.id }}";
  var tileType = "{{ block.settings.tile_type }}";
  var shopBtnColor = "{{ block.settings.shop_btn_color }}";
  var allVideos = [];
  var currentIndex = 0;

  fetch(API + "?shop=" + shop + "&page=home")
    .then(function(r) { return r.json(); })
    .then(function(data) {
      allVideos = data.videos || [];
      var container = document.getElementById("nq-carousel-" + blockId);
      container.innerHTML = "";

      if (!allVideos.length) {
        container.innerHTML = "<p style='padding:20px;color:#999;'>No videos yet.</p>";
        return;
      }

      allVideos.forEach(function(video, index) {
        var card = document.createElement("div");
        card.className = "nq-card nq-tile-" + tileType;
        card.onclick = function() { nqOpenPopup(blockId, index); };

        var videoEl = document.createElement("video");
        videoEl.src = video.r2_url;
        videoEl.muted = true;
        videoEl.loop = true;
        videoEl.playsInline = true;
        videoEl.style.cssText = "width:100%;height:100%;object-fit:cover;border-radius:12px;";

        // Autoplay on hover
        card.onmouseenter = function() { videoEl.play(); };
        card.onmouseleave = function() { videoEl.pause(); videoEl.currentTime = 0; };

        var views = document.createElement("div");
        views.className = "nq-views";
        views.innerHTML = "&#128065; " + (video.views || 0);

        var playIcon = document.createElement("div");
        playIcon.className = "nq-play-icon";
        playIcon.innerHTML = "&#9654;";

        card.appendChild(videoEl);
        card.appendChild(views);
        card.appendChild(playIcon);

        // ── Tile-type specific product rendering ──────────────────────────
        if (tileType === "img_transparent_text_overlay_3" ||
            tileType === "img_transparent_text_overlay_2") {
          // Transparent text overlay
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var overlay = document.createElement("div");
              overlay.className = "nq-overlay nq-overlay-transparent";
              overlay.innerHTML =
                '<p class="nq-overlay-title">' + product.title + '</p>' +
                '<p class="nq-overlay-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>' +
                '<a href="/products/' + product.handle + '" class="nq-shop-now" style="background:' + shopBtnColor + '">SHOP NOW</a>';
              card.appendChild(overlay);
            });
          }

        } else if (tileType === "img_opaque_text_overlay_3") {
          // Opaque text overlay
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var overlay = document.createElement("div");
              overlay.className = "nq-overlay nq-overlay-opaque";
              overlay.innerHTML =
                '<p class="nq-overlay-title">' + product.title + '</p>' +
                '<p class="nq-overlay-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>' +
                '<a href="/products/' + product.handle + '" class="nq-shop-now" style="background:' + shopBtnColor + '">SHOP NOW</a>';
              card.appendChild(overlay);
            });
          }

        } else if (tileType === "single_tile_no_overlay") {
          // No overlay – card only, no extra product info

        } else if (tileType === "product_below_3" || tileType === "product_below_2" || tileType === "product_below") {
          // Product info below card (default)
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var info = document.createElement("div");
              info.className = "nq-product-info";
              info.innerHTML =
                '<p class="nq-product-title">' + product.title + '</p>' +
                '<p class="nq-product-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>';
              card.appendChild(info);
            });
          }

        } else if (tileType === "story_format") {
          // Story-like format: full-width tall card with bottom overlay
          card.classList.add("nq-story");
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var overlay = document.createElement("div");
              overlay.className = "nq-overlay nq-overlay-story";
              overlay.innerHTML =
                '<p class="nq-overlay-title">' + product.title + '</p>' +
                '<p class="nq-overlay-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>' +
                '<a href="/products/' + product.handle + '" class="nq-shop-now" style="background:' + shopBtnColor + '">SHOP NOW</a>';
              card.appendChild(overlay);
            });
          }

        } else if (tileType === "feed_view_more") {
          // Feed with "View More" CTA
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var info = document.createElement("div");
              info.className = "nq-product-info";
              info.innerHTML =
                '<p class="nq-product-title">' + product.title + '</p>' +
                '<p class="nq-product-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>' +
                '<a href="/products/' + product.handle + '" class="nq-view-more">View More ›</a>';
              card.appendChild(info);
            });
          }

        } else if (tileType === "feed_on_scroll") {
          // Feed on scroll – lazy load style, product info below
          card.classList.add("nq-feed-scroll");
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var info = document.createElement("div");
              info.className = "nq-product-info";
              info.innerHTML =
                '<p class="nq-product-title">' + product.title + '</p>' +
                '<p class="nq-product-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>';
              card.appendChild(info);
            });
          }

        } else if (tileType === "grid_theme_border") {
          // Grid with themed border
          card.classList.add("nq-grid-border");
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var info = document.createElement("div");
              info.className = "nq-product-info";
              info.innerHTML =
                '<p class="nq-product-title">' + product.title + '</p>' +
                '<p class="nq-product-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>';
              card.appendChild(info);
            });
          }

        } else if (tileType === "grid_no_border") {
          // Grid without border
          card.classList.add("nq-grid-no-border");
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var info = document.createElement("div");
              info.className = "nq-product-info";
              info.innerHTML =
                '<p class="nq-product-title">' + product.title + '</p>' +
                '<p class="nq-product-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>';
              card.appendChild(info);
            });
          }

        } else if (tileType === "3d_navigation") {
          // 3D navigation carousel card
          card.classList.add("nq-3d");
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var overlay = document.createElement("div");
              overlay.className = "nq-overlay nq-overlay-transparent";
              overlay.innerHTML =
                '<p class="nq-overlay-title">' + product.title + '</p>' +
                '<p class="nq-overlay-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>' +
                '<a href="/products/' + product.handle + '" class="nq-shop-now" style="background:' + shopBtnColor + '">SHOP NOW</a>';
              card.appendChild(overlay);
            });
          }

        } else if (tileType === "minimal") {
          // Minimal – video card only, no product details

        } else {
          // Fallback: product info below
          if (video.product_ids && video.product_ids.length > 0) {
            fetchProduct(video.product_ids[0]).then(function(product) {
              if (!product) return;
              var info = document.createElement("div");
              info.className = "nq-product-info";
              info.innerHTML =
                '<p class="nq-product-title">' + product.title + '</p>' +
                '<p class="nq-product-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>';
              card.appendChild(info);
            });
          }
        }
        // ──────────────────────────────────────────────────────────────────

        container.appendChild(card);
      });

      // Scroll buttons
      var prevBtn = document.createElement("button");
      prevBtn.className = "nq-scroll-btn nq-scroll-prev";
      prevBtn.innerHTML = "&#10094;";
      prevBtn.onclick = function() { container.scrollBy({ left: -300, behavior: "smooth" }); };

      var nextBtn = document.createElement("button");
      nextBtn.className = "nq-scroll-btn nq-scroll-next";
      nextBtn.innerHTML = "&#10095;";
      nextBtn.onclick = function() { container.scrollBy({ left: 300, behavior: "smooth" }); };

      container.parentElement.appendChild(prevBtn);
      container.parentElement.appendChild(nextBtn);
    });

  function fetchProduct(productId) {
    var numericId = productId.replace("gid://shopify/Product/", "");
    return fetch("/products.json?ids=" + numericId)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        return data.products && data.products[0] ? data.products[0].variants[0] ? {
          title: data.products[0].title,
          price: data.products[0].variants[0].price * 100,
          handle: data.products[0].handle,
          image: data.products[0].images[0] ? data.products[0].images[0].src : null
        } : null : null;
      }).catch(function() { return null; });
  }

  window.nqOpenPopup = function(bid, index) {
    if (bid !== blockId) return;
    currentIndex = index;
    nqShowPopupVideo(bid);
    document.getElementById("nq-popup-" + bid).classList.add("active");
    document.body.style.overflow = "hidden";
  };

  window.nqClosePopup = function(bid) {
    if (bid !== blockId) return;
    var popup = document.getElementById("nq-popup-" + bid);
    popup.classList.remove("active");
    document.getElementById("nq-popup-video-" + bid).pause();
    document.body.style.overflow = "";
  };

  window.nqPrevVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex - 1 + allVideos.length) % allVideos.length;
    nqShowPopupVideo(bid);
  };

  window.nqNextVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex + 1) % allVideos.length;
    nqShowPopupVideo(bid);
  };

  function nqShowPopupVideo(bid) {
    var video = allVideos[currentIndex];
    var videoEl = document.getElementById("nq-popup-video-" + bid);
    videoEl.src = video.r2_url;
    videoEl.play();

    var productDiv = document.getElementById("nq-popup-product-" + bid);
    productDiv.innerHTML = "";

    if (video.product_ids && video.product_ids.length > 0) {
      fetchProduct(video.product_ids[0]).then(function(product) {
        if (!product) return;
        productDiv.innerHTML =
          '<div class="nq-popup-product-card">' +
          (product.image ? '<img src="' + product.image + '" alt="' + product.title + '">' : '') +
          '<div class="nq-popup-product-info">' +
          '<p class="nq-popup-product-title">' + product.title + '</p>' +
          '<p class="nq-popup-product-price">₹' + (parseInt(product.price) / 100).toLocaleString('en-IN') + '</p>' +
          '</div>' +
          '<a href="/products/' + product.handle + '" class="nq-shop-now" style="background:' + shopBtnColor + '">SHOP NOW</a>' +
          '</div>';
      });
    }
  }
})();
</script>

{% schema %}
{
  "name": "NQ Video Carousel",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch And Buy"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading Font Size - Desktop (px)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading Font Size - Mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal Padding (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical Padding (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Video Card Height (px)",
      "min": 200,
      "max": 600,
      "step": 20,
      "default": 340
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Video Card Width (px)",
      "min": 120,
      "max": 400,
      "step": 10,
      "default": 220
    },
    {
      "type": "select",
      "id": "tile_type",
      "label": "Tile Type",
      "info": "'2 tiles' and '3 tiles' refer to the layout in mobile view",
      "options": [
        { "value": "img_transparent_text_overlay_3", "label": "Video Card-Img & Transparent Text Overlay-3 tiles" },
        { "value": "img_transparent_text_overlay_2", "label": "Video Card-Img & Transparent Text Overlay-2 tiles" },
        { "value": "img_opaque_text_overlay_3",      "label": "Video Card-Img & Opaque Text Overlay-3 tiles" },
        { "value": "single_tile_no_overlay",          "label": "Video Card-Single Tile (No Overlay)" },
        { "value": "product_below_3",                 "label": "Video Card-Product Info Below tile-3 tiles" },
        { "value": "product_below_2",                 "label": "Video Card-Product Info Below tile-2 tiles" },
        { "value": "story_format",                    "label": "Video Card-Story Like Format" },
        { "value": "feed_view_more",                  "label": "Video Card Feed-View More" },
        { "value": "feed_on_scroll",                  "label": "Video Card Feed-On Scroll" },
        { "value": "grid_theme_border",               "label": "Video Card Grid-Theme Border" },
        { "value": "grid_no_border",                  "label": "Video Card Grid-No Border" },
        { "value": "3d_navigation",                   "label": "Video Card 3D Navigation" },
        { "value": "minimal",                         "label": "Video Card Minimal" }
      ],
      "default": "product_below_3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "shop_btn_color",
      "label": "Shop Now Button Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_views",
      "label": "Show view count",
      "default": true
    }
  ]
}
{% endschema %}
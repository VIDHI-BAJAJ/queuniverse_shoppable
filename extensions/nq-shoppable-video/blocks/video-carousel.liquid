{{ 'nq-carousel.css' | asset_url | stylesheet_tag }}

<div class="nq-section nq-tile-type-{{ block.settings.tile_type }}"
     style="padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;">

  <h2 class="nq-heading"
      style="font-size: {{ block.settings.heading_size_desktop }}px; color: {{ block.settings.heading_color }};">
    {{ block.settings.heading }}
  </h2>

  {% assign tt = block.settings.tile_type %}

  {% if tt == 'feed_on_scroll' or tt == 'grid_theme_border' or tt == 'grid_no_border' %}
    <div class="nq-grid" id="nq-carousel-{{ block.id }}">
      <div class="nq-loading">Loading videos...</div>
    </div>

  {% elsif tt == '3d_navigation' %}
    <div class="nq-3d-wrap">
      <button class="nq-3d-prev" id="nq-3d-prev-{{ block.id }}">&#10094;</button>
      <div class="nq-3d-track" id="nq-carousel-{{ block.id }}"></div>
      <button class="nq-3d-next" id="nq-3d-next-{{ block.id }}">&#10095;</button>
    </div>

  {% else %}
    <div class="nq-carousel-wrap">
      <div class="nq-carousel" id="nq-carousel-{{ block.id }}">
        <div class="nq-loading">Loading videos...</div>
      </div>
      <button class="nq-scroll-btn nq-scroll-prev" id="nq-prev-{{ block.id }}">&#10094;</button>
      <button class="nq-scroll-btn nq-scroll-next" id="nq-next-{{ block.id }}">&#10095;</button>
    </div>
  {% endif %}

  {% if tt == 'feed_view_more' %}
    <div class="nq-view-more-wrap">
      <button class="nq-view-more-btn">VIEW MORE &#8964;</button>
    </div>
  {% endif %}

</div>

<!-- Fullscreen Popup -->
<div class="nq-popup" id="nq-popup-{{ block.id }}">
  <div class="nq-popup-overlay" onclick="nqClosePopup('{{ block.id }}')"></div>
  <div class="nq-popup-content">
    <button class="nq-popup-close" onclick="nqClosePopup('{{ block.id }}')">&#10005;</button>
    <button class="nq-popup-prev" onclick="nqPrevVideo('{{ block.id }}')">&#10094;</button>
    <div class="nq-popup-video-wrap">
      <video class="nq-popup-video" id="nq-popup-video-{{ block.id }}" autoplay muted playsinline controls></video>
      <div class="nq-popup-product" id="nq-popup-product-{{ block.id }}"></div>
    </div>
    <button class="nq-popup-next" onclick="nqNextVideo('{{ block.id }}')">&#10095;</button>
  </div>
</div>

<script>
(function() {
  var shop     = "{{ shop.permanent_domain }}";
  var API      = "https://queuniverse-shoppable.vercel.app/api/videos";
  var blockId  = "{{ block.id }}";
  var tileType = "{{ block.settings.tile_type }}";
  var btnColor = "{{ block.settings.shop_btn_color }}";
  var cardH    = {{ block.settings.card_height }};
  var cardW    = {{ block.settings.card_width }};
  var allVideos = [];
  var currentIndex = 0;
  var active3D = 0;

  fetch(API + "?shop=" + shop + "&page=home")
    .then(function(r) { return r.json(); })
    .then(function(data) {
      allVideos = data.videos || [];
      var container = document.getElementById("nq-carousel-" + blockId);
      if (!container) return;
      container.innerHTML = "";

      if (!allVideos.length) {
        container.innerHTML = "<p class='nq-empty'>No videos yet.</p>";
        return;
      }

      allVideos.forEach(function(video, index) {
        container.appendChild(buildCard(video, index));
      });

      if (tileType === "feed_on_scroll") {
        initScrollReveal(container);
      } else if (tileType === "3d_navigation") {
        init3D();
      } else {
        initScrollBtns();
      }
    });

  /* ───────────────────────── Card Builder ───────────────────────── */
  function buildCard(video, index) {
    var card = document.createElement("div");
    card.className = "nq-card nq-tile-" + tileType;

    var videoEl = document.createElement("video");
    videoEl.src = video.r2_url;
    videoEl.muted = true;
    videoEl.loop = true;
    videoEl.playsInline = true;
    videoEl.className = "nq-video-el";

    card.onmouseenter = function() { videoEl.play(); };
    card.onmouseleave = function() { videoEl.pause(); videoEl.currentTime = 0; };
    card.onclick = function() { nqOpenPopup(blockId, index); };

    var views = document.createElement("div");
    views.className = "nq-views";
    views.innerHTML = "&#128065; " + (video.views || 0);

    card.appendChild(videoEl);
    card.appendChild(views);

    switch (tileType) {

      /* 1 & 2 — Transparent overlay: thumbnail + title at bottom of video */
      case "img_transparent_text_overlay_3":
      case "img_transparent_text_overlay_2":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        if (video.product_ids && video.product_ids.length) {
          fetchProduct(video.product_ids[0]).then(function(p) {
            if (!p) return;
            var ov = document.createElement("div");
            ov.className = "nq-ov-transparent";
            ov.innerHTML =
              (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
              '<span class="nq-ov-title">' + p.title + '</span>';
            card.appendChild(ov);
          });
        }
        break;

      /* 3 — Opaque white card overlapping bottom of video */
      case "img_opaque_text_overlay_3":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;overflow:visible;";
        if (video.product_ids && video.product_ids.length) {
          fetchProduct(video.product_ids[0]).then(function(p) {
            if (!p) return;
            var ov = document.createElement("div");
            ov.className = "nq-ov-opaque";
            ov.innerHTML =
              (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
              '<div class="nq-ov-text">' +
                '<span class="nq-ov-title">' + p.title + '</span>' +
                '<span class="nq-ov-price">&#8377;' + fmt(p.price) + '</span>' +
              '</div>';
            card.appendChild(ov);
          });
        }
        break;

      /* 4 — Single tile, smaller, no product */
      case "single_tile_no_overlay":
        card.style.cssText += "width:" + Math.round(cardW * 0.72) + "px;height:" + Math.round(cardH * 0.65) + "px;";
        break;

      /* 5 & 6 — Product info below card */
      case "product_below_3":
      case "product_below_2":
      case "product_below":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;overflow:visible;";
        if (video.product_ids && video.product_ids.length) {
          fetchProduct(video.product_ids[0]).then(function(p) {
            if (!p) return;
            var discHtml = '';
            if (p.compare_at_price && p.compare_at_price > p.price) {
              var pct = Math.round((p.compare_at_price - p.price) / p.compare_at_price * 100);
              discHtml =
                '<span class="nq-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>' +
                '<span class="nq-disc-badge">' + pct + '% off</span>';
            }
            var info = document.createElement("div");
            info.className = "nq-below-info";
            info.innerHTML =
              '<p class="nq-below-title">' + p.title + '</p>' +
              '<p class="nq-below-price">&#8377;' + fmt(p.price) + ' ' + discHtml + '</p>';
            card.appendChild(info);
          });
        }
        break;

      /* 7 — Story: circular card */
      case "story_format":
        card.style.cssText += "width:110px;height:110px;border-radius:50%;";
        views.style.display = "none";
        break;

      /* 8 — Feed View More: horizontal carousel + transparent overlay inside */
      case "feed_view_more":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        if (video.product_ids && video.product_ids.length) {
          fetchProduct(video.product_ids[0]).then(function(p) {
            if (!p) return;
            var ov = document.createElement("div");
            ov.className = "nq-ov-transparent";
            ov.innerHTML =
              (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
              '<span class="nq-ov-title">' + p.title + '</span>';
            card.appendChild(ov);
          });
        }
        break;

      /* 9 — Feed On Scroll: 2-col grid, fade-in, product below */
      case "feed_on_scroll":
        card.classList.add("nq-scroll-fade");
        if (video.product_ids && video.product_ids.length) {
          fetchProduct(video.product_ids[0]).then(function(p) {
            if (!p) return;
            var priceRow = '&#8377;' + fmt(p.price);
            if (p.compare_at_price && p.compare_at_price > p.price) {
              priceRow += ' <span class="nq-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>';
            }
            var info = document.createElement("div");
            info.className = "nq-below-info";
            info.innerHTML =
              '<p class="nq-below-title">' + p.title + '</p>' +
              '<p class="nq-below-price">' + priceRow + '</p>';
            card.appendChild(info);
          });
        }
        break;

      /* 10 — Grid Theme Border: rounded coloured border, no product info */
      case "grid_theme_border":
        card.style.border = "3px solid " + btnColor;
        break;

      /* 11 — Grid No Border: flush grid, no border */
      case "grid_no_border":
        card.style.borderRadius = "0";
        break;

      /* 12 — 3D Navigation */
      case "3d_navigation":
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        if (video.product_ids && video.product_ids.length) {
          fetchProduct(video.product_ids[0]).then(function(p) {
            if (!p) return;
            var ov = document.createElement("div");
            ov.className = "nq-ov-transparent";
            ov.innerHTML =
              (p.image ? '<img src="' + p.image + '" class="nq-ov-thumb">' : '') +
              '<span class="nq-ov-title">' + p.title + '</span>';
            card.appendChild(ov);
          });
        }
        break;

      /* 13 — Minimal */
      case "minimal":
      default:
        card.style.cssText += "width:" + cardW + "px;height:" + cardH + "px;";
        break;
    }

    return card;
  }

  /* ───────────────────────── Helpers ───────────────────────── */
  function fmt(cents) {
    // cents are stored as paise (price * 100), so divide back
    return (Math.round(parseInt(cents)) / 100).toLocaleString('en-IN', {minimumFractionDigits: 0, maximumFractionDigits: 0});
  }

  function fetchProduct(productId) {
    // Extract numeric ID from GID or use as-is if already numeric
    var id = productId.replace("gid://shopify/Product/", "");
    // Use /products.json with handle search as fallback, primary: storefront by id
    return fetch("/products.json?limit=1&ids=" + id)
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var pr = d.products && d.products[0];
        if (!pr || !pr.variants || !pr.variants[0]) return null;
        var v = pr.variants[0];
        // Shopify REST API returns price as string e.g. "1899.00"
        var price = Math.round(parseFloat(v.price) * 100);
        var comparePrice = v.compare_at_price ? Math.round(parseFloat(v.compare_at_price) * 100) : null;
        return {
          title:           pr.title,
          price:           price,
          compare_at_price: comparePrice,
          handle:          pr.handle,
          image:           pr.images && pr.images[0] ? pr.images[0].src : null
        };
      }).catch(function() { return null; });
  }

  /* ───────────────────────── Scroll Buttons ─────────────────── */
  function initScrollBtns() {
    var container = document.getElementById("nq-carousel-" + blockId);
    var prev = document.getElementById("nq-prev-" + blockId);
    var next = document.getElementById("nq-next-" + blockId);

    function updateArrows() {
      if (prev) prev.disabled = container.scrollLeft <= 2;
      if (next) next.disabled = container.scrollLeft + container.clientWidth >= container.scrollWidth - 2;
    }

    if (prev) prev.onclick = function() {
      container.scrollBy({ left: -(cardW + 12), behavior: "smooth" });
      setTimeout(updateArrows, 350);
    };
    if (next) next.onclick = function() {
      container.scrollBy({ left: (cardW + 12), behavior: "smooth" });
      setTimeout(updateArrows, 350);
    };

    container.addEventListener("scroll", updateArrows, { passive: true });
    updateArrows(); // set initial state
  }

  /* ───────────────────────── Scroll Reveal ──────────────────── */
  function initScrollReveal(container) {
    var cards = container.querySelectorAll(".nq-scroll-fade");
    if (!("IntersectionObserver" in window)) {
      cards.forEach(function(c) { c.classList.add("nq-visible"); });
      return;
    }
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add("nq-visible"); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    cards.forEach(function(c) { io.observe(c); });
  }

  /* ───────────────────────── 3D Coverflow ──────────────────── */
  function init3D() {
    var track   = document.getElementById("nq-carousel-" + blockId);
    var prevBtn = document.getElementById("nq-3d-prev-" + blockId);
    var nextBtn = document.getElementById("nq-3d-next-" + blockId);
    var cards   = track.querySelectorAll(".nq-card");
    active3D    = Math.floor(cards.length / 2);

    function render() {
      cards.forEach(function(card, i) {
        var diff  = i - active3D;
        var abs   = Math.abs(diff);
        var scale = abs === 0 ? 1 : abs === 1 ? 0.80 : 0.65;
        var tx    = diff * (cardW * 0.68);
        var tz    = abs === 0 ? 0 : -100;
        var ry    = diff * -24;
        var op    = abs === 0 ? 1 : abs === 1 ? 0.65 : 0.40;
        card.style.cssText +=
          ";transform:translateX(" + tx + "px) translateZ(" + tz + "px) rotateY(" + ry + "deg) scale(" + scale + ")" +
          ";opacity:" + op +
          ";z-index:" + (20 - abs) +
          ";transition:all 0.4s cubic-bezier(.4,0,.2,1)";
      });
    }

    if (prevBtn) prevBtn.onclick = function() { if (active3D > 0) { active3D--; render(); } };
    if (nextBtn) nextBtn.onclick = function() { if (active3D < cards.length - 1) { active3D++; render(); } };
    render();
  }

  /* ───────────────────────── Popup ─────────────────────────── */
  window.nqOpenPopup = function(bid, index) {
    if (bid !== blockId) return;
    currentIndex = index;
    showPopup(bid);
    document.getElementById("nq-popup-" + bid).classList.add("active");
    document.body.style.overflow = "hidden";
  };

  window.nqClosePopup = function(bid) {
    if (bid !== blockId) return;
    document.getElementById("nq-popup-" + bid).classList.remove("active");
    document.getElementById("nq-popup-video-" + bid).pause();
    document.body.style.overflow = "";
  };

  window.nqPrevVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex - 1 + allVideos.length) % allVideos.length;
    showPopup(bid);
  };

  window.nqNextVideo = function(bid) {
    if (bid !== blockId) return;
    currentIndex = (currentIndex + 1) % allVideos.length;
    showPopup(bid);
  };

  function showPopup(bid) {
    var video   = allVideos[currentIndex];
    var videoEl = document.getElementById("nq-popup-video-" + bid);
    videoEl.src = video.r2_url;
    videoEl.play();

    var pd = document.getElementById("nq-popup-product-" + bid);
    pd.innerHTML = "";

    if (video.product_ids && video.product_ids.length) {
      fetchProduct(video.product_ids[0]).then(function(p) {
        if (!p) return;

        // Build price line with compare-at if available
        var priceHtml = '&#8377;' + fmt(p.price);
        var compareHtml = '';
        if (p.compare_at_price && p.compare_at_price > p.price) {
          compareHtml = '<span class="nq-popup-orig-price">&#8377;' + fmt(p.compare_at_price) + '</span>';
        }

        pd.innerHTML =
          '<div class="nq-popup-product-card">' +
            (p.image ? '<img src="' + p.image + '" class="nq-popup-thumb">' : '') +
            '<div class="nq-popup-product-info">' +
              '<p class="nq-popup-product-title">' + p.title + '</p>' +
              '<p class="nq-popup-product-price">' + priceHtml + ' ' + compareHtml + '</p>' +
            '</div>' +
          '</div>' +
          '<a href="/products/' + p.handle + '" class="nq-popup-shop-btn" style="background:' + btnColor + '">SHOP NOW</a>';
      });
    }
  }
})();
</script>

{% schema %}
{
  "name": "NQ Video Carousel",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch And Buy"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading Font Size - Desktop (px)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading Font Size - Mobile (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal Padding (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical Padding (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Video Card Height (px)",
      "min": 200,
      "max": 600,
      "step": 20,
      "default": 340
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Video Card Width (px)",
      "min": 120,
      "max": 400,
      "step": 10,
      "default": 200
    },
    {
      "type": "select",
      "id": "tile_type",
      "label": "Tile Type",
      "info": "'2 tiles' and '3 tiles' refer to the layout in mobile view",
      "options": [
        { "value": "img_transparent_text_overlay_3", "label": "Video Card-Img & Transparent Text Overlay-3 tiles" },
        { "value": "img_transparent_text_overlay_2", "label": "Video Card-Img & Transparent Text Overlay-2 tiles" },
        { "value": "img_opaque_text_overlay_3",      "label": "Video Card-Img & Opaque Text Overlay-3 tiles" },
        { "value": "single_tile_no_overlay",          "label": "Video Card-Single Tile (No Overlay)" },
        { "value": "product_below_3",                 "label": "Video Card-Product Info Below tile-3 tiles" },
        { "value": "product_below_2",                 "label": "Video Card-Product Info Below tile-2 tiles" },
        { "value": "story_format",                    "label": "Video Card-Story Like Format" },
        { "value": "feed_view_more",                  "label": "Video Card Feed-View More" },
        { "value": "feed_on_scroll",                  "label": "Video Card Feed-On Scroll" },
        { "value": "grid_theme_border",               "label": "Video Card Grid-Theme Border" },
        { "value": "grid_no_border",                  "label": "Video Card Grid-No Border" },
        { "value": "3d_navigation",                   "label": "Video Card 3D Navigation" },
        { "value": "minimal",                         "label": "Video Card Minimal" }
      ],
      "default": "product_below_3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "shop_btn_color",
      "label": "Shop Now Button Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_views",
      "label": "Show view count",
      "default": true
    }
  ]
}
{% endschema %}
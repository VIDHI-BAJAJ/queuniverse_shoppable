{{ 'nq-floating.css' | asset_url | stylesheet_tag }}

{% if product %}
<div class="nq-float-wrap" id="nq-float-{{ block.id }}" style="display:none;">
  <button class="nq-float-close" id="nq-float-close-{{ block.id }}">&#10005;</button>
  <div class="nq-float-video-wrap">
    <video
      class="nq-float-video"
      id="nq-float-video-{{ block.id }}"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <button class="nq-float-mute" id="nq-float-mute-{{ block.id }}">&#128263;</button>
  </div>
</div>

<script>
(function() {
  var shop      = "{{ shop.permanent_domain }}";
  var productId = "{{ product.id }}";
  var blockId   = "{{ block.id }}";
  var API       = "https://queuniverse-shoppable.vercel.app/api/videos";
  var apiURL    = API + "?shop=" + shop + "&product_id=gid://shopify/Product/" + productId;
  var isMuted   = true;

  var wrap    = document.getElementById("nq-float-" + blockId);
  var videoEl = document.getElementById("nq-float-video-" + blockId);
  var closeBtn = document.getElementById("nq-float-close-" + blockId);
  var muteBtn = document.getElementById("nq-float-mute-" + blockId);

  // Fetch video for this product
  fetch(apiURL)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var videos = data.videos || [];
      if (!videos.length) return; // no video for this product — stay hidden

      // Load first video
      videoEl.src = videos[0].r2_url;
      videoEl.muted = true;
      videoEl.play().catch(function(){});

      // Track view via Vercel API (uses service role key securely)
      try {
        fetch("https://queuniverse-shoppable.vercel.app/api/track?video_id=" + videos[0].id + "&shop=" + shop, {
          keepalive: true
        }).catch(function(){});
      } catch(e) {}

      // Show the widget
      wrap.style.display = "block";
      setTimeout(function() { wrap.classList.add("nq-float-visible"); }, 100);
    })
    .catch(function() {});

  // Close button — sets manuallyClosed so it won't reappear
  if (closeBtn) {
    closeBtn.onclick = function() {
      manuallyClosed = true;
      wrap.classList.remove("nq-float-visible");
      setTimeout(function() { wrap.style.display = "none"; }, 300);
      videoEl.pause();
    };
  }

  // Mute toggle
  if (muteBtn) {
    muteBtn.onclick = function() {
      isMuted = !isMuted;
      videoEl.muted = isMuted;
      muteBtn.innerHTML = isMuted ? "&#128263;" : "&#128266;";
    };
  }

  // Hide floating video when Add to Cart button comes into view
  function hideFloat() {
    wrap.classList.remove("nq-float-visible");
    setTimeout(function() { wrap.style.display = "none"; }, 300);
    videoEl.pause();
  }

  var manuallyClosed = false;

  function showFloat() {
    if (manuallyClosed) return; // respect manual close
    wrap.style.display = "block";
    setTimeout(function() { wrap.classList.add("nq-float-visible"); }, 100);
    videoEl.play().catch(function(){});
  }

  // Watch Add to Cart / Buy Now buttons using IntersectionObserver
  // When button is VISIBLE on screen → hide float
  // When button scrolls OUT of view → show float again
  function watchCartButtons() {
    var selectors = [
      '[name="add"]',
      '[id*="add-to-cart"]',
      '[id*="AddToCart"]',
      '.add-to-cart',
      '[data-testid*="add-to-cart"]',
      'button[type="submit"].product-form__cart-submit',
      '.product-form__submit',
      '#ProductSubmitButton',
      '.btn--add-to-cart',
      '[data-add-to-cart]'
    ];

    var cartBtn = null;
    for (var i = 0; i < selectors.length; i++) {
      cartBtn = document.querySelector(selectors[i]);
      if (cartBtn) break;
    }

    // Fallback: find by text
    if (!cartBtn) {
      var buttons = document.querySelectorAll("button, input[type=submit]");
      for (var j = 0; j < buttons.length; j++) {
        var txt = (buttons[j].textContent || buttons[j].value || "").toLowerCase();
        if (txt.includes("add to cart") || txt.includes("buy now") || txt.includes("sold out")) {
          cartBtn = buttons[j];
          break;
        }
      }
    }

    if (!cartBtn) return; // no cart button found

    // Simple rule:
    // Cart button NOT YET reached (still below viewport) → show video
    // Cart button visible OR scrolled past → hide video

    function checkCartButtonPosition() {
      var rect = cartBtn.getBoundingClientRect();
      var viewH = window.innerHeight;

      // Button is still below the screen = user hasn't scrolled to it yet
      if (rect.top > viewH) {
        // Button not yet reached — show floating video
        showFloat();
      } else {
        // Button is visible OR user scrolled past it — hide floating video
        hideFloat();
      }
    }

    window.addEventListener("scroll", checkCartButtonPosition, { passive: true });
    checkCartButtonPosition();
  }

  // Start watching after video loads
  setTimeout(watchCartButtons, 1000);

})();
</script>
{% endif %}

{% schema %}
{
  "name": "NQ Floating Video",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "position",
      "label": "Widget Position",
      "options": [
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-left",  "label": "Bottom Left" }
      ],
      "default": "bottom-right"
    },
    {
      "type": "range",
      "id": "widget_width",
      "label": "Widget Width (px) — Desktop",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 160
    },
    {
      "type": "range",
      "id": "widget_width_mobile",
      "label": "Widget Width (px) — Mobile",
      "min": 80,
      "max": 200,
      "step": 10,
      "default": 110
    }
  ]
}
{% endschema %}
{{ 'nq-floating.css' | asset_url | stylesheet_tag }}

{% if product %}
<div class="nq-float-wrap" id="nq-float-{{ block.id }}" style="display:none;">
  <button class="nq-float-close" id="nq-float-close-{{ block.id }}">&#10005;</button>
  <div class="nq-float-video-wrap">
    <video
      class="nq-float-video"
      id="nq-float-video-{{ block.id }}"
      autoplay muted loop playsinline
    ></video>
    <button class="nq-float-mute" id="nq-float-mute-{{ block.id }}">&#128263;</button>
  </div>
</div>

<script>
(function() {
  var shop      = "{{ shop.myshopify_domain }}";
  var productId = "{{ product.id }}";
  var blockId   = "{{ block.id }}";
  var API       = "https://queuniverse-shoppable.vercel.app/api/videos";
  var apiURL    = API + "?shop=" + shop + "&product_id=gid://shopify/Product/" + productId;
  var isMuted   = true;
  var manuallyClosed = false;

  var wrap     = document.getElementById("nq-float-" + blockId);
  var videoEl  = document.getElementById("nq-float-video-" + blockId);
  var closeBtn = document.getElementById("nq-float-close-" + blockId);
  var muteBtn  = document.getElementById("nq-float-mute-" + blockId);

  function hideFloat() {
    wrap.classList.remove("nq-float-visible");
    setTimeout(function() { wrap.style.display = "none"; }, 300);
    videoEl.pause();
  }

  function showFloat() {
    if (manuallyClosed) return;
    if (!videoEl.src) return;
    wrap.style.display = "block";
    setTimeout(function() { wrap.classList.add("nq-float-visible"); }, 100);
    videoEl.play().catch(function(){});
  }

  fetch(apiURL)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var allVideos = data.videos || [];

      var gid = "gid://shopify/Product/" + productId;
      var videos = allVideos.filter(function(v) {
        var ids = Array.isArray(v.product_ids) ? v.product_ids : [];
        return ids.indexOf(gid) >= 0 || ids.indexOf(productId) >= 0;
      });

      if (!videos.length) return;

      var video = videos[0];
      videoEl.src = video.r2_url;
      if (video.thumbnail_url) videoEl.poster = video.thumbnail_url;
      videoEl.muted = true;
      videoEl.play().catch(function(){});

      try {
        fetch("https://queuniverse-shoppable.vercel.app/api/track?video_id=" + video.id + "&shop=" + shop + "&event=view", {
          keepalive: true
        }).catch(function(){});
      } catch(e) {}

      wrap.style.display = "block";
      setTimeout(function() { wrap.classList.add("nq-float-visible"); }, 100);
      setTimeout(watchCartButtons, 800);
    })
    .catch(function() {});

  if (closeBtn) {
    closeBtn.onclick = function() {
      manuallyClosed = true;
      hideFloat();
    };
  }

  if (muteBtn) {
    muteBtn.onclick = function() {
      isMuted = !isMuted;
      videoEl.muted = isMuted;
      muteBtn.innerHTML = isMuted ? "&#128263;" : "&#128266;";
    };
  }

  function watchCartButtons() {
    var selectors = [
      '[name="add"]', '[id*="add-to-cart"]', '[id*="AddToCart"]',
      '.add-to-cart', '.product-form__submit', '#ProductSubmitButton',
      '.btn--add-to-cart', '[data-add-to-cart]',
      'button[type="submit"].product-form__cart-submit'
    ];

    var cartBtn = null;
    for (var i = 0; i < selectors.length; i++) {
      cartBtn = document.querySelector(selectors[i]);
      if (cartBtn) break;
    }

    if (!cartBtn) {
      var buttons = document.querySelectorAll("button, input[type=submit]");
      for (var j = 0; j < buttons.length; j++) {
        var txt = (buttons[j].textContent || buttons[j].value || "").toLowerCase();
        if (txt.includes("add to cart") || txt.includes("buy now") || txt.includes("sold out")) {
          cartBtn = buttons[j]; break;
        }
      }
    }

    if (!cartBtn) return;

    function checkPosition() {
      var rect = cartBtn.getBoundingClientRect();
      if (rect.top > window.innerHeight) {
        showFloat();
      } else {
        hideFloat();
      }
    }

    window.addEventListener("scroll", checkPosition, { passive: true });
    checkPosition();
  }

})();
</script>
{% endif %}

{% schema %}
{
  "name": "NQ Floating Video",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "position",
      "label": "Widget Position",
      "options": [
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-left",  "label": "Bottom Left" }
      ],
      "default": "bottom-right"
    },
    {
      "type": "range",
      "id": "widget_width",
      "label": "Widget Width (px) — Desktop",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 160
    },
    {
      "type": "range",
      "id": "widget_width_mobile",
      "label": "Widget Width (px) — Mobile",
      "min": 80,
      "max": 200,
      "step": 10,
      "default": 110
    }
  ]
}
{% endschema %}
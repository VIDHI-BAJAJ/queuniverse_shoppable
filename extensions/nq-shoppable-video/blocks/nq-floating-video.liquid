{{ 'nq-floating.css' | asset_url | stylesheet_tag }}

{% if product %}
<div class="nq-float-wrap" id="nq-float-{{ block.id }}" style="display:none;">
  <button class="nq-float-close" id="nq-float-close-{{ block.id }}">&#10005;</button>
  <div class="nq-float-video-wrap">
    <video
      class="nq-float-video"
      id="nq-float-video-{{ block.id }}"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <button class="nq-float-mute" id="nq-float-mute-{{ block.id }}">&#128263;</button>
  </div>
</div>

<script>
(function() {
  var shop      = "{{ shop.permanent_domain }}";
  var productId = "{{ product.id }}";
  var blockId   = "{{ block.id }}";
  var API       = "https://queuniverse-shoppable.vercel.app/api/videos";
  var apiURL    = API + "?shop=" + shop + "&product_id=gid://shopify/Product/" + productId;
  var isMuted   = true;

  var wrap    = document.getElementById("nq-float-" + blockId);
  var videoEl = document.getElementById("nq-float-video-" + blockId);
  var closeBtn = document.getElementById("nq-float-close-" + blockId);
  var muteBtn = document.getElementById("nq-float-mute-" + blockId);

  // Fetch video for this product
  fetch(apiURL)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var videos = data.videos || [];
      if (!videos.length) return; // no video for this product — stay hidden

      // Load first video
      videoEl.src = videos[0].r2_url;
      videoEl.muted = true;
      videoEl.play().catch(function(){});

      // Show the widget
      wrap.style.display = "block";
      setTimeout(function() { wrap.classList.add("nq-float-visible"); }, 100);
    })
    .catch(function() {});

  // Close button
  if (closeBtn) {
    closeBtn.onclick = function() {
      wrap.classList.remove("nq-float-visible");
      setTimeout(function() { wrap.style.display = "none"; }, 300);
      videoEl.pause();
    };
  }

  // Mute toggle
  if (muteBtn) {
    muteBtn.onclick = function() {
      isMuted = !isMuted;
      videoEl.muted = isMuted;
      muteBtn.innerHTML = isMuted ? "&#128263;" : "&#128266;";
    };
  }

  // Hide when Add to Cart is clicked
  function hideFloat() {
    wrap.classList.remove("nq-float-visible");
    setTimeout(function() { wrap.style.display = "none"; }, 300);
    videoEl.pause();
  }

  // Listen for Add to Cart button clicks
  document.addEventListener("click", function(e) {
    var target = e.target;
    // Check if clicked element or its parent is an add to cart button
    var addToCart = target.closest
      ? target.closest('[name="add"], [id*="add-to-cart"], .add-to-cart, [data-testid*="add-to-cart"]')
      : null;

    if (!addToCart) {
      // Fallback: check by text content
      var text = (target.textContent || "").toLowerCase().trim();
      var parentText = (target.parentElement && target.parentElement.textContent || "").toLowerCase().trim();
      if (text.includes("add to cart") || text.includes("buy now") ||
          parentText.includes("add to cart")) {
        addToCart = target;
      }
    }

    if (addToCart) {
      hideFloat();
    }
  });

  // Also listen for form submissions (add to cart form)
  document.addEventListener("submit", function(e) {
    var form = e.target;
    if (form && (form.action || "").includes("/cart/add")) {
      hideFloat();
    }
  });

})();
</script>
{% endif %}

{% schema %}
{
  "name": "NQ Floating Video",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "position",
      "label": "Widget Position",
      "options": [
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-left",  "label": "Bottom Left" }
      ],
      "default": "bottom-right"
    },
    {
      "type": "range",
      "id": "widget_width",
      "label": "Widget Width (px) — Desktop",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 160
    },
    {
      "type": "range",
      "id": "widget_width_mobile",
      "label": "Widget Width (px) — Mobile",
      "min": 80,
      "max": 200,
      "step": 10,
      "default": 110
    }
  ]
}
{% endschema %}